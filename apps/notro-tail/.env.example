# Required: Notion API credentials
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATASOURCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: Site metadata overrides (defaults defined in src/config.ts)
# PUBLIC_SITE_NAME=My Blog
# PUBLIC_SITE_URL=https://example.com
# PUBLIC_SITE_DESCRIPTION=My personal blog
# PUBLIC_BLOG_POSTS_PER_PAGE=10
