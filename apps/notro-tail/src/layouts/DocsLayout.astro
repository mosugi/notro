---
// Docs layout with sticky sidebar navigation.
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SeoHead from "../components/SeoHead.astro";
import { isActive } from "../lib/nav";

interface NavItem {
  label: string;
  href: string;
}

interface NavGroup {
  title: string;
  items: NavItem[];
}

interface Props {
  title: string;
  description?: string;
  /** Page heading shown above the main content */
  heading: string;
}

const { title, description, heading } = Astro.props;
const pathname = Astro.url.pathname;
const canonicalUrl = new URL(pathname, Astro.site ?? Astro.url.origin).toString();

const navGroups: NavGroup[] = [
  {
    title: "はじめに",
    items: [
      { label: "概要・クイックスタート", href: "/docs/" },
    ],
  },
  {
    title: "セットアップ",
    items: [
      { label: "Notion セットアップ", href: "/docs/notion-setup/" },
      { label: "カスタマイズ", href: "/docs/customization/" },
      { label: "デプロイガイド", href: "/docs/deploy/" },
    ],
  },
  {
    title: "リファレンス",
    items: [
      { label: "API リファレンス", href: "/docs/api-reference/" },
      { label: "アーキテクチャ", href: "/docs/architecture/" },
    ],
  },
  {
    title: "レンダリング検証",
    items: [
      { label: "ブロックタイプ一覧", href: "/docs/rendering/" },
    ],
  },
];

// Bind isActive to the current pathname
const active = (href: string) => isActive(pathname, href);
---

<!doctype html>
<html lang="ja">
  <head>
    <SeoHead title={title} description={description} canonicalUrl={canonicalUrl} />
  </head>
  <body>
    <Header />

    <div class="mx-auto max-w-screen-xl px-4 sm:px-6 lg:px-8">
      <!-- Mobile: collapsible nav above content -->
      <div class="lg:hidden pt-6 pb-2">
        <button
          id="docs-sidebar-toggle"
          class="flex items-center gap-2 text-sm nt-text-65 border nt-border-15 rounded-md px-3 py-1.5 transition-[color,background] hover:nt-bg-05 dark:text-slate-400 dark:border-white/15 dark:hover:bg-white/5"
          aria-expanded="false"
          aria-controls="docs-sidebar-mobile"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          ドキュメントメニュー
        </button>
        <div
          id="docs-sidebar-mobile"
          class="hidden mt-3 mb-4 rounded-lg border nt-border p-4 dark:border-white/8"
        >
          {navGroups.map((group) => (
            <div class="mb-4 last:mb-0">
              <p class="mb-1 text-xs font-semibold uppercase tracking-wider nt-text-45 dark:text-slate-500">
                {group.title}
              </p>
              <ul class="space-y-0.5">
                {group.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        "block rounded-[5px] px-2 py-1 text-sm no-underline transition-[color,background]",
                        active(item.href)
                          ? "font-medium text-[#2383e2] dark:text-blue-400"
                          : "nt-text-70 hover:nt-text dark:text-slate-400 dark:hover:text-slate-200",
                      ]}
                      aria-current={active(item.href) ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- Desktop: sidebar + content side by side -->
      <div class="flex gap-8 py-10 lg:gap-12">

        <!-- Desktop sidebar (hidden on mobile) -->
        <aside class="hidden lg:block w-56 shrink-0">
          <nav class="sticky top-20" aria-label="ドキュメントナビゲーション">
            {navGroups.map((group) => (
              <div class="mb-6">
                <p class="mb-1.5 text-xs font-semibold uppercase tracking-wider nt-text-45 dark:text-slate-500">
                  {group.title}
                </p>
                <ul class="space-y-0.5">
                  {group.items.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class:list={[
                          "block rounded-[5px] px-2.5 py-1.5 text-sm no-underline transition-[color,background]",
                          active(item.href)
                            ? "bg-[rgba(35,131,226,0.08)] font-medium text-[#2383e2] dark:bg-blue-950 dark:text-blue-400"
                            : "nt-text-70 hover:nt-bg-05 hover:nt-text dark:text-slate-400 dark:hover:bg-white/5 dark:hover:text-slate-200",
                        ]}
                        aria-current={active(item.href) ? "page" : undefined}
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </nav>
        </aside>

        <!-- Main content -->
        <main id="main-content" class="min-w-0 flex-1">
          <h1 class="mb-2 text-3xl font-bold tracking-tight nt-text dark:text-slate-100">{heading}</h1>
          <slot />
        </main>

      </div>
    </div>

    <Footer />

    <script>
      const btn = document.getElementById("docs-sidebar-toggle");
      const sidebar = document.getElementById("docs-sidebar-mobile");
      btn?.addEventListener("click", () => {
        sidebar?.classList.toggle("hidden");
        const isOpen = !sidebar?.classList.contains("hidden");
        btn.setAttribute("aria-expanded", String(isOpen));
      });
    </script>
  </body>
</html>
