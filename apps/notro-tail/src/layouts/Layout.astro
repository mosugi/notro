---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SeoHead from "../components/SeoHead.astro";
import config from "../config";

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  /** og:type — defaults to "website"; use "article" for blog posts */
  type?: "website" | "article";
}

const { title, description, bodyClass, type = "website" } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
---

<!doctype html>
<html lang={config.site.lang}>
  <head>
    <SeoHead title={title} description={description} canonicalUrl={canonicalUrl} type={type} />
  </head>
  <body class={bodyClass}>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
