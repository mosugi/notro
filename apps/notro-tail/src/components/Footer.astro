---
import { getCollection } from "astro:content";
import { getPagePropertyText } from "notro";

const footerPages = await getCollection("pages", ({ data }) => {
  const type = getPagePropertyText(data.properties, "Placement");
  return type?.includes("Footer");
});
---

{
  footerPages.length > 0 ? (
    <footer>
      <div>
        <ul>
          {footerPages.map(({ data }) => (
            <li>
              <a href={"/" + getPagePropertyText(data.properties, "Slug")}>
                {getPagePropertyText(data.properties, "Name")}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </footer>
  ) : null
}
