---
---

<style>
  footer {
    border-top: 1px solid rgba(55, 53, 47, 0.09);
    margin-top: 4rem;
  }
  .footer-inner {
    padding: 3rem 0 0;
  }
  .footer-grid {
    display: grid;
    gap: 2.5rem;
    margin-bottom: 3rem;
  }
  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 2rem; }
  }

  /* Brand column */
  .footer-logo {
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #37352f;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 0.625rem;
    transition: opacity 0.15s;
  }
  .footer-logo:hover { opacity: 0.7; }
  .footer-desc {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: rgba(55, 53, 47, 0.45);
    max-width: 240px;
  }

  /* Link columns */
  .footer-col-title {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(55, 53, 47, 0.4);
    margin-bottom: 0.875rem;
  }
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-links a {
    font-size: 0.875rem;
    color: rgba(55, 53, 47, 0.55);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-links a:hover { color: #37352f; }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(55, 53, 47, 0.07);
    padding: 1.25rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .footer-copy {
    font-size: 0.8125rem;
    color: rgba(55, 53, 47, 0.35);
  }
  .footer-social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .footer-social a {
    color: rgba(55, 53, 47, 0.35);
    transition: color 0.15s;
    display: flex;
    align-items: center;
  }
  .footer-social a:hover { color: #37352f; }
</style>

<footer>
  <div class="mx-auto max-w-screen-xl px-4 sm:px-6 lg:px-8">
    <div class="footer-inner">
      <div class="footer-grid">

        <!-- Brand -->
        <div>
          <a href="/" class="footer-logo">NotroTail</a>
          <p class="footer-desc">
            Notion を CMS として使う<br />Astro 静的サイトジェネレーター。
          </p>
        </div>

        <!-- Explore -->
        <div>
          <p class="footer-col-title">コンテンツ</p>
          <div class="footer-links">
            <a href="/blog/">ブログ</a>
            <a href="/blog/about/">About</a>
          </div>
        </div>

        <!-- Docs -->
        <div>
          <p class="footer-col-title">ドキュメント</p>
          <div class="footer-links">
            <a href="/docs/">Docs</a>
            <a href="https://www.npmjs.com/package/notro" target="_blank" rel="noopener noreferrer">npm</a>
          </div>
        </div>

        <!-- Legal -->
        <div>
          <p class="footer-col-title">法的情報</p>
          <div class="footer-links">
            <a href="/blog/privacy/">プライバシーポリシー</a>
          </div>
        </div>

      </div>

      <!-- Bottom bar -->
      <div class="footer-bottom">
        <span class="footer-copy">&copy; {new Date().getFullYear()} NotroTail</span>
        <div class="footer-social">
          <!-- GitHub -->
          <a href="https://github.com/mosugi/notro-tail" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
          </a>
          <!-- npm -->
          <a href="https://www.npmjs.com/package/notro" target="_blank" rel="noopener noreferrer" aria-label="npm">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M0 7.334v8h6.666v1.332H12v-1.332h12v-8H0zm6.666 6.664H5.334v-4H3.999v4H1.335V8.667h5.331v5.331zm4 0v1.336H8.001V8.667h5.334v5.332h-2.669v-.001zm12.001 0h-1.33v-4h-1.336v4h-1.335v-4h-1.33v4h-2.671V8.667h8.002v5.331z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
