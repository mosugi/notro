---
import config from "../config";
import { buildBlogPostingJsonLd, buildWebSiteJsonLd } from "../lib/seo";

interface Props {
  title: string;
  description?: string;
  canonicalUrl: string;
  /** og:type — defaults to "website"; use "article" for blog posts */
  type?: "website" | "article";
  ogImage?: string;
  /** Alt text for the og:image (also used for twitter:image:alt) */
  ogImageAlt?: string;
  /** ISO 8601 date string for article published date */
  datePublished?: string;
  /** Previous page URL for paginated pages */
  prevUrl?: string;
  /** Next page URL for paginated pages */
  nextUrl?: string;
  /** Prevent search engines from indexing this page */
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalUrl,
  type = "website",
  ogImage = "/og-default.png",
  ogImageAlt,
  datePublished,
  prevUrl,
  nextUrl,
  noindex = false,
} = Astro.props;

const baseUrl = (Astro.site ?? Astro.url.origin).toString();
const rssUrl = new URL("/rss.xml", baseUrl).toString();
const ogImageAbsolute = new URL(ogImage, baseUrl).toString();

const jsonLd =
  type === "article"
    ? buildBlogPostingJsonLd({
        title,
        description,
        datePublished,
        image: ogImageAbsolute,
        url: canonicalUrl,
        author: config.site.author,
        publisher: config.site.name,
      })
    : buildWebSiteJsonLd(config.site.name, baseUrl);

const measurementId = config.analytics.gaMeasurementId;
---

<meta charset="UTF-8" />
{description && <meta name="description" content={description} />}
<meta name="viewport" content="width=device-width" />
{noindex && <meta name="robots" content="noindex,nofollow" />}
<link rel="icon" type="image/svg+xml" href={config.favicon.svg} />
{config.favicon.png && <link rel="icon" type="image/png" href={config.favicon.png} />}
{config.favicon.appleTouchIcon && <link rel="apple-touch-icon" href={config.favicon.appleTouchIcon} />}
<link rel="manifest" href="/manifest.json" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={`${config.site.name} — RSS フィード`} href={rssUrl} />
<link rel="canonical" href={canonicalUrl} />
{prevUrl && <link rel="prev" href={new URL(prevUrl, baseUrl).toString()} />}
{nextUrl && <link rel="next" href={new URL(nextUrl, baseUrl).toString()} />}
<link rel="stylesheet" href="/katex/katex.min.css" />
<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:locale" content={config.site.locale} />
<meta property="og:site_name" content={config.site.name} />
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageAbsolute} />
{ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
<!-- Open Graph article-specific tags -->
{type === "article" && datePublished && <meta property="article:published_time" content={datePublished} />}
{type === "article" && <meta property="article:author" content={config.site.author} />}
<!-- Twitter Card -->
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
<meta name="twitter:image" content={ogImageAbsolute} />
{ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}
<!-- JSON-LD structured data -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
<!-- Google Analytics via Partytown (only when gaMeasurementId is set in config.ts) -->
{measurementId && (
  <Fragment>
    <script is:inline type="text/partytown" src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`} />
    <script is:inline type="text/partytown" set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config',${JSON.stringify(measurementId)});`} />
  </Fragment>
)}
<title>{title}</title>
