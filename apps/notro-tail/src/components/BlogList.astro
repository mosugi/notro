---
import type { CollectionEntry } from "astro:content";
import { getPlainText, getMultiSelect, OptimizedDatabaseCover } from "notro";

interface Props {
  posts: CollectionEntry<"posts">["data"][];
}

const { posts } = Astro.props;
---

<style>
  .post-card {
    display: block;
    border-radius: 6px;
    border: 1px solid rgba(55, 53, 47, 0.09);
    background: #ffffff;
    overflow: hidden;
    transition: box-shadow 0.15s, border-color 0.15s;
    text-decoration: none;
    color: inherit;
  }
  .post-card:hover {
    border-color: rgba(55, 53, 47, 0.18);
    box-shadow: rgba(15, 15, 15, 0.06) 0px 2px 8px;
  }
  .post-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #37352f;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
    transition: color 0.1s;
  }
  .post-card:hover .post-title {
    color: #2383e2;
  }
  .post-description {
    font-size: 0.8125rem;
    color: rgba(55, 53, 47, 0.65);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.5;
    margin-top: 0.25rem;
  }
  .post-date {
    font-size: 0.75rem;
    color: rgba(55, 53, 47, 0.45);
    display: block;
    margin-bottom: 0.25rem;
  }
  .post-tag {
    font-size: 0.6875rem;
    background: rgba(55, 53, 47, 0.06);
    color: rgba(55, 53, 47, 0.65);
    border-radius: 3px;
    padding: 0.1rem 0.4rem;
  }
</style>

{
  posts.length > 0 ? (
    <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((data) => {
        const slug = getPlainText(data.properties.Slug) || data.id;
        const title = getPlainText(data.properties.Name);
        const description = getPlainText(data.properties.Description);
        const date = data.properties.Date?.type === "date" ? data.properties.Date.date?.start : undefined;
        const tags = getMultiSelect(data.properties.Tags);
        return (
          <li>
            <a href={`/blog/${slug}/`} class="post-card group block h-full">
              <OptimizedDatabaseCover
                cover={data.cover}
                alt={title}
                class="[&_img]:h-40 [&_img]:w-full [&_img]:object-cover"
              />
              <div class="p-4">
                {date && (
                  <time datetime={date} class="post-date">
                    {date}
                  </time>
                )}
                <p class="post-title">{title}</p>
                {description && (
                  <p class="post-description">{description}</p>
                )}
                {tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-1">
                    {tags.map((tag) => (
                      <span class="post-tag">{tag.name}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  ) : null
}
