---
/**
 * Custom Callout component for NotroTail.
 * Overrides notro's base Callout with TailwindCSS styling.
 *
 * This is a sample showing how to fully override a notro component
 * via the `components` prop on <NotionMarkdownRenderer />.
 *
 * Usage in [slug].astro:
 *   import Callout from "../../components/notion/Callout.astro";
 *   <NotionMarkdownRenderer components={{ callout: Callout }} ... />
 */
import { colorToCSS } from "notro";

interface Props {
	icon?: string;
	color?: string;
}

const { icon, color } = Astro.props;
---

<div
	class="notion-callout flex items-start gap-3 my-4 rounded-lg border border-gray-200 bg-gray-50 p-4"
	style={colorToCSS(color)}
>
	{icon && <span class="text-xl leading-none shrink-0">{icon}</span>}
	<div class="min-w-0 flex-1 [&>:first-child]:mt-0 [&>:last-child]:mb-0">
		<slot />
	</div>
</div>
