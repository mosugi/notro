---
/**
 * Sample custom Callout component for NotroTail.
 *
 * Demonstrates how to fully override a notro component via the `components`
 * prop on <NotionMarkdownRenderer />.
 *
 * This variant adds a visible border to all callouts, supplementing the
 * color background applied by notro-ui's [data-callout][data-color] selectors.
 */
interface Props {
	icon?: string;
	color?: string;
	class?: string;
}

const { icon, color, class: className } = Astro.props;
---

<div data-callout data-color={color || 'gray_background'} class:list={["border border-current/20", className]}>
	{icon && <span data-callout-icon aria-hidden="true">{icon}</span>}
	<div data-callout-body>
		<slot />
	</div>
</div>
