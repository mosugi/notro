---
/**
 * Notion quote block — renders as <blockquote>.
 */
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import { notroColorVariants } from './colors';

export const quote = tv({
  base: 'my-4 border-l-4 border-[var(--notro-blue)] pl-5 text-[var(--notro-text-muted)] [&>p:first-child]:mt-0 [&>p:last-child]:mb-0',
  variants: { color: notroColorVariants },
});

interface Props extends Omit<HTMLAttributes<'blockquote'>, 'color'>, VariantProps<typeof quote> {}

const { color, class: className, ...rest } = Astro.props;
---

<blockquote class={quote({ color, class: className })} {...rest}>
  <slot />
</blockquote>
