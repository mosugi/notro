---
/**
 * Notion page reference link.
 */
import { colorToClass } from './colors';
interface Props { url: string; color?: string; class?: string; }
const { url, color, class: className } = Astro.props;
---
<a
  href={url}
  class:list={["inline-flex items-center gap-1 underline underline-offset-2 hover:opacity-70", colorToClass(color), className]}
>
  <span class="text-[0.9em]" aria-hidden="true">📄</span>
  <slot />
</a>
