---
/**
 * Explicit empty line spacer.
 */
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

export const emptyBlock = tv({ base: 'my-2' });

type Props = HTMLAttributes<'div'>;

const { class: className, ...rest } = Astro.props;
---

<div class={emptyBlock({ class: className })} aria-hidden="true" data-slot="empty-block" {...rest}></div>
