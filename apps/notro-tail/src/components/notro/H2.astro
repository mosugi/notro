---
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import { notroColorVariants } from './colors';

export const h2 = tv({
  base: 'mb-2 mt-6 text-2xl font-semibold tracking-tight',
  variants: { color: notroColorVariants },
});

interface Props extends Omit<HTMLAttributes<'h2'>, 'color'>, VariantProps<typeof h2> {}

const { color, class: className, ...rest } = Astro.props;
---
<h2 class={h2({ color, class: className })} {...rest}><slot /></h2>
