---
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import { notroColorVariants } from './colors';

export const h2 = tv({
  base: 'mb-2 mt-8 text-2xl font-semibold tracking-tight',
  variants: { color: notroColorVariants },
  defaultVariants: { color: 'default' },
});

type Props = Omit<HTMLAttributes<'h2'>, 'color'> & VariantProps<typeof h2>;

const { color, class: className, ...rest } = Astro.props;
---
<h2 class={h2({ color, class: className })} data-slot="h2" {...rest}><slot /></h2>
