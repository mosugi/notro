---
/**
 * Site-local Notion renderer — delegates to notro's NotionMarkdownRenderer
 * with per-site component overrides.
 *
 * To customize a component: edit the corresponding file in this directory.
 * To add a new override: import it here and add it to the components map.
 */
import { NotionMarkdownRenderer as BaseRenderer } from 'notro';
import type { LinkToPages } from 'notro';

import Callout from './Callout.astro';
import H1     from './H1.astro';
import H2     from './H2.astro';
import Quote  from './Quote.astro';

interface Props {
  markdown: string;
  linkToPages?: LinkToPages;
  class?: string;
}

const { markdown, linkToPages, class: className } = Astro.props;

const overrides = { callout: Callout, h1: H1, h2: H2, blockquote: Quote };
---

<BaseRenderer {markdown} {linkToPages} class={className} components={overrides} />
