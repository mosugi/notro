---
/**
 * Notion video embed block.
 */
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

export const video = tv({
  slots: {
    root: 'my-4',
    controls: 'w-full',
    caption: 'text-sm text-[var(--notro-text-muted)] mt-1.5',
  },
});

interface Props extends HTMLAttributes<'figure'> {
  src: string;
}

const { src, class: className, ...rest } = Astro.props;
const { root, controls, caption } = video();
---

<figure class={root({ class: className })} {...rest}>
  <video controls src={src} class={controls()}></video>
  {Astro.slots.has('default') && (
    <figcaption class={caption()}>
      <slot />
    </figcaption>
  )}
</figure>
