---
import { tv, type VariantProps } from 'tailwind-variants';
import { notroColorVariants } from './colors';

export const h1 = tv({
  base: 'mb-3 mt-8 text-[1.875rem] font-bold tracking-tight',
  variants: { color: notroColorVariants },
});

interface Props extends VariantProps<typeof h1> {
  id?: string;
  class?: string;
}

const { color, id, class: className } = Astro.props;
---
<h1 {id} class={h1({ color, class: className })}><slot /></h1>
