---
/**
 * Notion file attachment block.
 */
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

export const fileBlock = tv({
  slots: {
    root: 'my-2',
    link: 'inline-flex items-center gap-1.5 text-[var(--notro-text)] underline underline-offset-2 hover:opacity-70',
    icon: 'text-base',
  },
});

interface Props extends HTMLAttributes<'div'> {
  src: string;
}

const { src, class: className, ...rest } = Astro.props;
const { root, link, icon } = fileBlock();
---

<div class={root({ class: className })} {...rest}>
  <a
    href={src}
    target="_blank"
    rel="noopener noreferrer"
    class={link()}
  >
    <span class={icon()} aria-hidden="true">📎</span>
    <slot />
  </a>
</div>
