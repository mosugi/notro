---
/**
 * Notion audio embed block.
 */
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

export const audio = tv({ base: 'my-4' });

interface Props extends HTMLAttributes<'figure'> {
  src: string;
}

const { src, class: className, ...rest } = Astro.props;
---

<figure class={audio({ class: className })} {...rest}>
  <audio controls src={src} class="w-full"></audio>
  {Astro.slots.has('default') && (
    <figcaption class="text-sm text-[var(--notro-text-muted)] mt-1.5">
      <slot />
    </figcaption>
  )}
</figure>
