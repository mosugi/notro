---
/**
 * Paragraph element with optional Notion block-level color support.
 *
 * Notion emits block-level color annotations as raw HTML:
 *   <p color="gray_bg">...</p>
 * This component applies the corresponding CSS class from notroColorVariants.
 */
import { tv, type VariantProps } from 'tailwind-variants';
import { notroColorVariants } from './colors';

export const coloredP = tv({
  base: 'mb-4 leading-7',
  variants: { color: notroColorVariants },
});

interface Props extends VariantProps<typeof coloredP> {
  class?: string;
}

const { color, class: className } = Astro.props;
---
<p class={coloredP({ color, class: className })}><slot /></p>
