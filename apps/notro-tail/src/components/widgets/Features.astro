---
interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  features?: Feature[];
}

const defaultFeatures: Feature[] = [
  {
    icon: "📦",
    title: "Notion Content Loader",
    description:
      "Astro Content Collections を Notion Public API で動かす。last_edited_time による差分ビルドで高速なインクリメンタルビルドを実現。",
  },
  {
    icon: "🧩",
    title: "コンポーネントマッピング",
    description:
      "コールアウト・カラム・トグル・KaTeX 数式など、Notion ブロックを MDX evaluate() + コンポーネントマッピングで Astro コンポーネントに変換。",
  },
  {
    icon: "🎨",
    title: "TailwindCSS 4",
    description:
      "Notion コンポーネントごとにスコープされたスタイル。classMap prop でクラス上書き、bodyClass でページ別テーマに対応。",
  },
  {
    icon: "🖼️",
    title: "画像の最適化",
    description:
      "Notion の期限付き S3 プリサインド URL から X-Amz-* パラメーターを除去し、ビルド間でキャッシュを再利用するカスタム Astro 画像サービス。",
  },
  {
    icon: "📄",
    title: "ページネーション付きブログ",
    description:
      "タグ・カテゴリフィルタリング対応の多ページブログ。ピン留め投稿・前後記事ナビゲーションもすぐに使えます。",
  },
  {
    icon: "📚",
    title: "npm ライブラリとして公開",
    description:
      "notro パッケージを任意の Astro プロジェクトに追加するだけ。ローダーとコンポーネントをドロップインで利用できます。",
  },
];

const { features = defaultFeatures } = Astro.props;
---

<section class="py-16 border-b nt-border">
  <p class="text-xs font-semibold tracking-[0.08em] uppercase text-[#2383e2] mb-3 dark:text-blue-400">機能</p>
  <h2 class="text-[clamp(1.375rem,2.5vw,1.75rem)] font-bold nt-text tracking-tight mb-2">必要なものがすべて揃っている</h2>
  <p class="text-[0.9375rem] nt-text-55 mb-10 dark:text-slate-300/55">Notion をヘッドレス CMS として使うためのフルスタック構成</p>
  <div class="grid gap-px nt-bg-09 border nt-border rounded-lg overflow-hidden sm:grid-cols-2 lg:grid-cols-3 dark:bg-white/6">
    {features.map(({ icon, title, description }) => (
      <div class="bg-white p-6 dark:bg-[#0f172a]">
        <div class="w-8 h-8 rounded-md flex items-center justify-center text-base mb-3 nt-bg-04 dark:bg-white/6">{icon}</div>
        <p class="text-[0.9375rem] font-semibold nt-text mb-1.5">{title}</p>
        <p class="text-[0.8125rem] leading-[1.6] nt-text-60 dark:text-slate-300/60">{description}</p>
      </div>
    ))}
  </div>
</section>
