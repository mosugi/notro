---
interface Package {
  badge: string;
  name: string;
  path: string;
  description: string;
}

interface Props {
  packages?: Package[];
}

const defaultPackages: Package[] = [
  {
    badge: "npm",
    name: "remark-nfm",
    path: "packages/remark-nfm/",
    description:
      "Notion Flavored Markdown 用の純粋な remark プラグイン。前処理・:::callout ディレクティブ・コールアウト変換をまとめて担当。Astro や Notion API に依存せず単独で npm 公開可能。",
  },
  {
    badge: "npm",
    name: "notro",
    path: "packages/notro/",
    description:
      "公開 npm ライブラリ本体。Astro Content Loader + MDX コンパイルパイプライン + Notion ブロックコンポーネントを提供。remark-nfm を内部で利用。",
  },
  {
    badge: "template",
    name: "notro-tail",
    path: "apps/notro-tail/",
    description:
      "デプロイ可能な Astro 6 ウェブサイト。notro の実装例として、ブログ・固定ページ・タグフィルタを含むテンプレート。",
  },
];

const { packages = defaultPackages } = Astro.props;
---

<section class="py-16 border-b border-[rgba(55,53,47,0.09)] dark:border-white/8">
  <p class="text-xs font-semibold tracking-[0.08em] uppercase text-[#2383e2] mb-3 dark:text-blue-400">モノレポ構成</p>
  <h2 class="text-[clamp(1.375rem,2.5vw,1.75rem)] font-bold text-[#37352f] tracking-tight mb-2 dark:text-slate-200">3 パッケージで責務を分割</h2>
  <p class="text-[0.9375rem] text-[rgba(55,53,47,0.55)] mb-10 dark:text-slate-300/55">それぞれ独立して利用・公開できる設計</p>
  <div class="grid gap-4 md:grid-cols-3">
    {packages.map(({ badge, name, path, description }) => (
      <div class="border border-[rgba(55,53,47,0.09)] rounded-lg p-5 bg-white dark:border-white/8 dark:bg-slate-800">
        <span class="inline-block text-[0.6875rem] bg-[rgba(35,131,226,0.1)] text-[#2383e2] rounded-[3px] px-1.5 py-0.5 mb-2 dark:bg-blue-400/12 dark:text-blue-400">{badge}</span>
        <p class="font-mono text-sm font-semibold text-[#37352f] mb-1.5 dark:text-slate-200">{name}</p>
        <p class="font-mono text-[0.6875rem] text-[rgba(55,53,47,0.4)] mb-2 dark:text-slate-300/40">{path}</p>
        <p class="text-[0.8125rem] leading-[1.55] text-[rgba(55,53,47,0.6)] dark:text-slate-300/60">{description}</p>
      </div>
    ))}
  </div>
</section>
