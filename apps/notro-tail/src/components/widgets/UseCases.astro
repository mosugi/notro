---
interface UseCase {
  icon: string;
  title: string;
  description: string;
  linkHref: string;
  linkLabel: string;
}

interface Props {
  cases?: UseCase[];
}

const defaultCases: UseCase[] = [
  {
    icon: "🚀",
    title: "テンプレートとして使う",
    description:
      "このリポジトリをテンプレートにして、Notion でコンテンツを書き、\nVercel / Netlify にワンクリックでデプロイ。5分で Notion ブログを立ち上げられます。",
    linkHref: "/docs/",
    linkLabel: "クイックスタートを見る →",
  },
  {
    icon: "📦",
    title: "npm パッケージとして使う",
    description:
      "既存の Astro プロジェクトに notro を追加するだけ。\nローダーとコンポーネントをドロップインで利用できます。remark-nfm は Astro なしでも使えます。",
    linkHref: "/docs/#api",
    linkLabel: "API リファレンスを見る →",
  },
];

const { cases = defaultCases } = Astro.props;
---

<section class="py-16 border-b border-[rgba(55,53,47,0.09)] dark:border-white/8">
  <p class="text-xs font-semibold tracking-[0.08em] uppercase text-[#2383e2] mb-3 dark:text-blue-400">使い方を選ぶ</p>
  <h2 class="text-[clamp(1.375rem,2.5vw,1.75rem)] font-bold text-[#37352f] tracking-tight mb-2 dark:text-slate-200">2つの使い方</h2>
  <div class="grid gap-4 mb-10 md:grid-cols-2">
    {cases.map(({ icon, title, description, linkHref, linkLabel }, i) => (
      <div class:list={[
        "border rounded-lg p-7 flex flex-col gap-3",
        i === 0
          ? "border-[rgba(35,131,226,0.25)] bg-[rgba(35,131,226,0.02)] dark:border-blue-400/25 dark:bg-blue-400/5"
          : "border-[rgba(55,53,47,0.12)] bg-white dark:border-white/10 dark:bg-slate-800",
      ]}>
        <div class="text-2xl">{icon}</div>
        <h3 class="text-[1.0625rem] font-semibold text-[#37352f] dark:text-slate-200">{title}</h3>
        <p class="text-sm leading-[1.65] text-[rgba(55,53,47,0.6)] flex-1 dark:text-slate-300/60">{description}</p>
        <a href={linkHref} class="text-sm font-medium text-[#2383e2] no-underline hover:underline dark:text-blue-400">{linkLabel}</a>
      </div>
    ))}
  </div>
</section>
