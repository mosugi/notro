---
import { getCollection } from "astro:content";
import { getPlainText } from "notro";
import { navPages } from "../config";

// Resolve navPages config against the content collection to get titles and slugs
const allPosts = await getCollection("posts");
const slugToEntry = new Map(
  allPosts.map((entry) => [getPlainText(entry.data.properties.Slug) || entry.id, entry]),
);
const fixedPages = navPages.flatMap((cfg) => {
  const entry = slugToEntry.get(cfg.slug);
  if (!entry) return [];
  return [{
    slug: cfg.slug,
    title: cfg.label ?? getPlainText(entry.data.properties.Name) ?? cfg.slug,
  }];
});

const pathname = Astro.url.pathname;
const fixedSlugs = new Set(fixedPages.map((p) => `/blog/${p.slug}/`));

// A link is "active" when the current pathname matches or starts with its href.
// Blog is excluded when a fixed page (e.g. /blog/about/) is the current page.
const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  if (href === "/blog/") return pathname.startsWith("/blog/") && !fixedSlugs.has(pathname);
  return pathname === href || pathname.startsWith(href);
};

const linkClass = (href: string) =>
  isActive(href)
    ? "font-medium transition"
    : "transition hover:opacity-70";
---

<style>
  header {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(55, 53, 47, 0.09);
  }
  .nav-logo {
    color: #37352f;
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
  }
  .nav-logo:hover {
    opacity: 0.7;
  }
  .nav-link {
    color: rgba(55, 53, 47, 0.65);
    font-size: 0.875rem;
  }
  .nav-link.active,
  .nav-link:hover {
    color: #37352f;
  }
  .nav-docs {
    background: #2383e2;
    color: #ffffff;
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: 4px;
    padding: 0.3rem 0.75rem;
    transition: opacity 0.15s;
  }
  .nav-docs:hover {
    opacity: 0.85;
  }
  .nav-docs.active {
    background: #1a5fb4;
  }
</style>

<header class="sticky top-0 z-10">
  <div class="mx-auto flex h-12 max-w-screen-xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="nav-logo">
      NotroTail
    </a>
    <nav>
      <ul class="flex items-center gap-5 text-sm">
        <li><a href="/" class:list={["nav-link", { active: isActive("/") }]}>ホーム</a></li>
        <li><a href="/blog/" class:list={["nav-link", { active: isActive("/blog/") }]}>ブログ</a></li>
        {fixedPages.map((p) => (
          <li>
            <a href={`/blog/${p.slug}/`} class:list={["nav-link", { active: isActive(`/blog/${p.slug}/`) }]}>
              {p.title}
            </a>
          </li>
        ))}
        <li>
          <a
            href="/contact/"
            class:list={["nav-docs", { active: isActive("/contact/") }]}
          >
            Docs
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
