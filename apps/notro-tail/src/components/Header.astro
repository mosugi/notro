---
import GitHubIcon from "./GitHubIcon.astro";
import MobileMenu from "./MobileMenu";
import { isActive } from "../lib/nav";
import config from "../config";

const pathname = Astro.url.pathname;

// Wrap isActive to bind the current pathname
const active = (href: string) => isActive(pathname, href);
---

<!-- Skip navigation link for keyboard and screen reader users -->
<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded">
  コンテンツへスキップ
</a>

<header class="sticky top-0 z-10 bg-white/90 backdrop-blur-md border-b nt-border-07 dark:bg-slate-800 dark:border-white/8">
  <div class="mx-auto flex h-14 max-w-screen-xl items-center justify-between px-4 sm:px-6 lg:px-8">

    <a href="/" class="font-bold text-base tracking-[-0.02em] nt-text no-underline transition-opacity hover:opacity-70">{config.site.name}</a>

    <!-- Desktop nav -->
    <nav aria-label="メインナビゲーション">
      <ul class="hidden sm:flex items-center gap-1">
        {config.navigation.nav.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                "relative text-sm no-underline px-2.5 py-1.5 rounded-md transition-[color,background]",
                active(href)
                  ? "nt-text font-medium after:content-[''] after:absolute after:bottom-[-1px] after:left-2.5 after:right-2.5 after:h-0.5 after:bg-[#2383e2] after:rounded-t-sm dark:text-slate-200 dark:after:bg-blue-400"
                  : "nt-text-60 hover:nt-text hover:nt-bg-05 dark:text-slate-400 dark:hover:text-slate-200 dark:hover:bg-white/5",
              ]}
              aria-current={active(href) ? "page" : undefined}
            >{label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Desktop GitHub + mobile hamburger -->
    <div class="flex items-center gap-2">
      <a
        href={config.navigation.social.github}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:inline-flex items-center gap-1.5 text-[0.8125rem] font-medium nt-text-65 no-underline px-3 py-1.5 border nt-border-15 rounded-md transition-[color,border-color,background] hover:nt-text hover:nt-border-30 hover:nt-bg-03 dark:text-slate-400 dark:border-white/15 dark:hover:text-slate-200 dark:hover:border-white/30 dark:hover:bg-white/3"
        aria-label="GitHub"
      >
        <GitHubIcon />
        GitHub
      </a>

      <!-- Mobile menu React island: focus trapping, Escape-to-close, click-outside via Headless UI -->
      <MobileMenu
        client:load
        navItems={config.navigation.nav}
        githubUrl={config.navigation.social.github}
        pathname={pathname}
      />
    </div>
  </div>

</header>
