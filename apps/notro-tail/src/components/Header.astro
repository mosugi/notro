---
const pathname = Astro.url.pathname;

// A link is "active" when the current pathname matches or starts with its href.
const isActive = (href: string) => pathname === href || pathname.startsWith(href);
---

<style>
  header {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(55, 53, 47, 0.09);
  }
  .nav-logo {
    color: #37352f;
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
    transition: opacity 0.15s ease;
  }
  .nav-logo { transition: opacity 0.15s; }
  .nav-logo:hover { opacity: 0.7; }
  .nav-link {
    font-size: 0.875rem;
    color: rgba(55, 53, 47, 0.55);
    transition: color 0.15s;
    text-decoration: none;
  }
  .nav-link:hover,
  .nav-link.active { color: #37352f; }
  .nav-link.active { font-weight: 500; }
  .nav-icon {
    display: flex;
    align-items: center;
    color: rgba(55, 53, 47, 0.45);
    transition: color 0.15s;
  }
  .nav-icon:hover { color: #37352f; }
</style>

<!-- Skip navigation link for keyboard and screen reader users -->
<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded">
  コンテンツへスキップ
</a>
<header class="sticky top-0 z-10">
  <div class="mx-auto flex h-12 max-w-screen-xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="nav-logo">NotroTail</a>
    <nav>
      <ul class="flex items-center gap-6">
        <li><a href="/blog/" class:list={["nav-link", { active: isActive("/blog/") }]} aria-current={isActive("/blog/") ? "page" : undefined}>ブログ</a></li>
        <li><a href="/blog/about/" class:list={["nav-link", { active: isActive("/blog/about/") }]} aria-current={isActive("/blog/about/") ? "page" : undefined}>About</a></li>
        <li><a href="/contact/" class:list={["nav-link", { active: isActive("/contact/") }]} aria-current={isActive("/contact/") ? "page" : undefined}>Docs</a></li>
        <li>
          <a href="https://github.com/mosugi/notro-tail" target="_blank" rel="noopener noreferrer" class="nav-icon" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
