---
/**
 * Reference implementation: SSR blog list page using liveLoader.
 *
 * To use this file:
 *   1. Copy to src/pages/live/index.astro
 *   2. Set up an SSR adapter (e.g. @astrojs/netlify) and output: 'server'
 *      in astro.config.mjs, OR use output: 'server' with per-page prerender.
 *   3. Ensure src/live.config.ts exists and exports a "posts" live collection.
 *
 * This page fetches all Notion pages on every request (no rebuild needed).
 */

// On-demand rendering: fetch from Notion on every request.
export const prerender = false;

import { getLiveCollection } from "astro:content";
import { getPlainText, getMultiSelect, hasTag } from "notro";
import Layout from "../../layouts/Layout.astro";
import { INTERNAL_TAGS, SITE_NAME, SITE_DESCRIPTION } from "../../config";

// Fetch all entries on this request. Returns { entries?, error?, cacheHint? }.
const result = await getLiveCollection("livePosts");

// On API error, show an empty list rather than crashing.
const allEntries = result.error ? [] : (result.entries ?? []);

// Filter out fixed pages (tagged "page") and sort by date descending
const posts = allEntries
  .filter((e) => !hasTag(e.data.properties.Tags, "page"))
  .sort((a, b) => {
    const dateA = a.data.properties.Date.date?.start ?? "";
    const dateB = b.data.properties.Date.date?.start ?? "";
    return dateB.localeCompare(dateA);
  });
---

<Layout title={`ブログ — ${SITE_NAME}`} description={SITE_DESCRIPTION}>
  <main class="mx-auto max-w-screen-xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-[720px]">
      <h1 class="mb-8 text-3xl font-bold tracking-tight text-[#37352f] dark:text-slate-200">
        ブログ
      </h1>

      {result.error && (
        <p class="mb-6 rounded-md border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700 dark:bg-red-950 dark:border-red-800 dark:text-red-400">
          コンテンツの取得中にエラーが発生しました。
        </p>
      )}

      {posts.length === 0 && !result.error && (
        <p class="text-[rgba(55,53,47,0.45)] dark:text-slate-500">記事がありません。</p>
      )}

      <ul class="space-y-6">
        {posts.map((entry) => {
          const slug = getPlainText(entry.data.properties.Slug) || entry.id;
          const title = getPlainText(entry.data.properties.Name) ?? entry.id;
          const description = getPlainText(entry.data.properties.Description);
          const date = entry.data.properties.Date.date?.start;
          const tags = getMultiSelect(entry.data.properties.Tags).filter(
            (t) => !INTERNAL_TAGS.includes(t.name),
          );
          return (
            <li>
              <a
                href={`/live/${slug}/`}
                class="block rounded-md border border-[rgba(55,53,47,0.09)] p-5 no-underline text-inherit transition-colors hover:bg-[rgba(55,53,47,0.03)] dark:border-white/8 dark:hover:bg-white/3"
              >
                <h2 class="mb-1 text-lg font-semibold text-[#37352f] dark:text-slate-200">
                  {title}
                </h2>
                {description && (
                  <p class="mb-2 text-sm leading-relaxed text-[rgba(55,53,47,0.65)] dark:text-slate-400 line-clamp-2">
                    {description}
                  </p>
                )}
                <div class="flex flex-wrap items-center gap-2">
                  {date && (
                    <time datetime={date} class="text-xs text-[rgba(55,53,47,0.45)] dark:text-slate-500">
                      {date}
                    </time>
                  )}
                  {tags.map((tag) => (
                    <span class="text-xs bg-[rgba(55,53,47,0.06)] text-[rgba(55,53,47,0.65)] rounded-[3px] px-1.5 py-0.5 dark:bg-white/6 dark:text-slate-400">
                      {tag.name}
                    </span>
                  ))}
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </main>
</Layout>
