---
/**
 * Reference implementation: SSR blog post page using liveLoader.
 *
 * To use this file:
 *   1. Copy to src/pages/blog/[slug].astro (replacing the existing file)
 *   2. Replace src/content.config.ts with src/examples/live.config.ts
 *      (rename to src/live.config.ts)
 *   3. Add an SSR adapter and set output: 'server' in astro.config.mjs
 *
 * This page fetches a single Notion page on every request (no rebuild needed).
 */

// On-demand rendering: fetch from Notion on every request.
export const prerender = false;

import { getLiveEntry, getLiveCollection } from "astro:content";
import { NotionMarkdownRenderer, buildLinkToPages, getPlainText, getMultiSelect, hasTag } from "notro";
import Layout from "../../layouts/Layout.astro";
import Callout from "../../components/notion/Callout.astro";
import { INTERNAL_TAGS, SITE_NAME } from "../../config";

const { slug } = Astro.params;

// getLiveEntry accepts the Notion page ID or a slug-based filter.
// To look up by slug, fetch all entries and find the matching one.
const allResult = await getLiveCollection("posts");
const allEntries = allResult.entries ?? [];

const entry = allEntries.find(
  (e) => (getPlainText(e.data.properties.Slug) || e.id) === slug,
);

if (!entry) {
  return Astro.redirect("/404");
}

// Build linkToPages map for resolving inter-page links in Notion content.
const linkToPages = buildLinkToPages(allEntries, {
  url: (e) => `blog/${getPlainText(e.data.properties.Slug) || e.id}/`,
  title: (e) => getPlainText(e.data.properties.Name) ?? e.id,
});

const title = getPlainText(entry.data.properties.Name) ?? entry.id;
const description = getPlainText(entry.data.properties.Description);
const date = entry.data.properties.Date.date?.start;
const isEmbeddedPage = hasTag(entry.data.properties.Tags, "page");
const tags = getMultiSelect(entry.data.properties.Tags).filter(
  (t) => !INTERNAL_TAGS.includes(t.name),
);
---

<Layout title={`${title} — ${SITE_NAME}`} description={description} type={isEmbeddedPage ? "website" : "article"}>
  <main id="main-content" class="mx-auto max-w-screen-xl px-4 py-10 sm:px-6 lg:px-8">
    <article class="mx-auto max-w-[720px]">
      <header class="mb-10 pb-6 border-b border-[rgba(55,53,47,0.09)] dark:border-white/8">
        <h1 class="mb-3 text-[2rem] font-bold tracking-tight leading-tight text-[#37352f] dark:text-slate-200">
          {title}
        </h1>
        {description && (
          <p class="mb-4 text-base leading-relaxed text-[rgba(55,53,47,0.65)] dark:text-slate-400">
            {description}
          </p>
        )}
        {!isEmbeddedPage && (
          <div class="flex flex-wrap items-center gap-3">
            {date && (
              <time datetime={date} class="text-sm text-[rgba(55,53,47,0.45)] dark:text-slate-500">
                {date}
              </time>
            )}
            {tags.length > 0 && (
              <ul class="flex list-none flex-wrap gap-1.5">
                {tags.map((tag) => (
                  <li>
                    <a
                      href={`/blog/tag/${tag.name}/`}
                      class="text-xs bg-[rgba(55,53,47,0.06)] text-[rgba(55,53,47,0.65)] rounded-[3px] px-2 py-0.5 no-underline transition-colors hover:bg-[rgba(55,53,47,0.1)] dark:bg-white/6 dark:text-slate-400"
                    >
                      {tag.name}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        )}
      </header>

      <NotionMarkdownRenderer
        markdown={entry.data.markdown}
        linkToPages={linkToPages}
        classMap={{
          callout:     "flex items-start gap-3 my-4 rounded-md p-4",
          toggle:      "my-1",
          toggleTitle: "cursor-pointer select-none py-1 font-medium",
          columns:     "grid grid-cols-1 gap-8 my-4 md:grid-cols-2",
          column:      "min-w-0",
          quote:       "my-4 border-l-[3px] pl-4 italic",
          h1:          "mb-3 mt-10 text-[1.875rem] font-bold tracking-tight",
          h2:          "mb-2 mt-8 text-2xl font-semibold tracking-tight",
          h3:          "mb-2 mt-6 text-xl font-semibold",
          h4:          "mb-1 mt-4 text-base font-semibold",
          image:       "my-4",
          tableWrapper:"my-4 w-full overflow-x-auto",
          table:       "w-full border-collapse text-sm",
          tableCell:   "px-3 py-2 text-sm",
          toc:         "my-4 rounded-md p-4 text-sm",
          p:           "mb-4 leading-7",
          ul:          "mb-4 list-disc pl-6 space-y-1",
          ol:          "mb-4 list-decimal pl-6 space-y-1",
          li:          "leading-7",
          pre:         "my-4 overflow-x-auto rounded-md p-4 font-mono text-sm",
          hr:          "my-8",
          a:           "underline underline-offset-2 hover:opacity-70",
          strong:      "font-semibold",
          em:          "italic",
          del:         "line-through",
          th:          "px-3 py-2 text-left text-sm font-semibold",
        }}
        components={{ callout: Callout }}
      />

      {entry.data.truncated && (
        <div class="mt-8 rounded-md border border-yellow-300 bg-yellow-50 px-4 py-3 text-sm text-amber-900 dark:bg-amber-950 dark:border-amber-800 dark:text-amber-400">
          このページのコンテンツは Notion API の制限により一部省略されています。
        </div>
      )}
    </article>
  </main>
</Layout>
