---
import { getCollection } from "astro:content";
import { NotionMarkdownRenderer, getPlainText } from "notro";
import Layout from "../layouts/Layout.astro";

const posts = await getCollection("posts");
const entry = posts.find(
  (e) => getPlainText(e.data.properties.Slug) === "about"
);
---

<Layout title="About — NotroTail" description="NotroTail は Notion を CMS として使う Astro 静的サイトジェネレーターです。" bodyClass="page-about">
  <main class="mx-auto max-w-screen-xl px-4 py-12 sm:px-6 lg:px-8">
    <article class="mx-auto max-w-[720px]">

      <header class="mb-10 pb-6" style="border-bottom: 1px solid rgba(55,53,47,0.09);">
        <h1 class="text-[2rem] font-bold tracking-tight leading-tight mb-3" style="color: #37352f;">
          このサイトについて
        </h1>
        <p class="text-base leading-relaxed" style="color: rgba(55,53,47,0.65);">
          <strong>NotroTail</strong> は Notion をコンテンツ管理システム（CMS）として使い、
          Astro で高速な静的サイトを生成するテンプレートです。
        </p>
      </header>

      {entry ? (
        <div class="nt-markdown-content">
          <NotionMarkdownRenderer
            markdown={entry.data.markdown}
            classMap={{
              callout:     "flex items-start gap-3 my-4 rounded-md p-4",
              toggle:      "my-1",
              toggleTitle: "cursor-pointer select-none py-1 font-medium",
              columns:     "grid grid-cols-1 gap-8 my-4 md:grid-cols-2",
              column:      "min-w-0",
              quote:       "my-4 border-l-[3px] pl-4 italic",
              h1:          "mb-3 mt-10 text-[1.875rem] font-bold tracking-tight",
              h2:          "mb-2 mt-8 text-2xl font-semibold tracking-tight",
              h3:          "mb-2 mt-6 text-xl font-semibold",
              h4:          "mb-1 mt-4 text-base font-semibold",
              image:       "my-4",
              tableWrapper:"my-4 w-full overflow-x-auto",
              table:       "w-full border-collapse text-sm",
              tableCell:   "px-3 py-2 text-sm",
              p:           "mb-4 leading-7",
              ul:          "mb-4 list-disc pl-6 space-y-1",
              ol:          "mb-4 list-decimal pl-6 space-y-1",
              li:          "leading-7",
              pre:         "my-4 overflow-x-auto rounded-md p-4 font-mono text-sm",
              hr:          "my-8",
              a:           "underline underline-offset-2 hover:opacity-70",
              strong:      "font-semibold",
              em:          "italic",
              del:         "line-through",
              th:          "px-3 py-2 text-left text-sm font-semibold",
            }}
          />
        </div>
      ) : (
        <>
          <section class="mb-10">
            <h2 class="mb-4 text-xl font-semibold" style="color: #37352f;">技術スタック</h2>
            <div class="overflow-x-auto rounded-lg" style="border: 1px solid rgba(55,53,47,0.09);">
              <table class="w-full text-sm">
                <thead style="background: rgba(55,53,47,0.03);">
                  <tr>
                    <th class="px-4 py-3 text-left font-semibold" style="color: rgba(55,53,47,0.65);">技術</th>
                    <th class="px-4 py-3 text-left font-semibold" style="color: rgba(55,53,47,0.65);">役割</th>
                  </tr>
                </thead>
                <tbody style="divide-y divide-[rgba(55,53,47,0.06)];">
                  <tr style="border-top: 1px solid rgba(55,53,47,0.06);">
                    <td class="px-4 py-3"><a href="https://notion.so" class="underline underline-offset-2 hover:opacity-70" style="color: #2383e2;">Notion</a></td>
                    <td class="px-4 py-3" style="color: rgba(55,53,47,0.65);">コンテンツ管理</td>
                  </tr>
                  <tr style="border-top: 1px solid rgba(55,53,47,0.06);">
                    <td class="px-4 py-3"><a href="https://astro.build" class="underline underline-offset-2 hover:opacity-70" style="color: #2383e2;">Astro 6</a></td>
                    <td class="px-4 py-3" style="color: rgba(55,53,47,0.65);">静的サイトジェネレーター</td>
                  </tr>
                  <tr style="border-top: 1px solid rgba(55,53,47,0.06);">
                    <td class="px-4 py-3"><a href="https://tailwindcss.com" class="underline underline-offset-2 hover:opacity-70" style="color: #2383e2;">TailwindCSS 4</a></td>
                    <td class="px-4 py-3" style="color: rgba(55,53,47,0.65);">スタイリング</td>
                  </tr>
                  <tr style="border-top: 1px solid rgba(55,53,47,0.06);">
                    <td class="px-4 py-3"><a href="https://github.com/mosugi/notro-tail" class="underline underline-offset-2 hover:opacity-70" style="color: #2383e2;">notro</a></td>
                    <td class="px-4 py-3" style="color: rgba(55,53,47,0.65);">Notion → Astro ローダー・MDX コンパイラ</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>

          <section class="mb-10">
            <h2 class="mb-4 text-xl font-semibold" style="color: #37352f;">特徴</h2>
            <ul class="space-y-2 pl-6 list-disc" style="color: rgba(55,53,47,0.8);">
              <li class="leading-7"><strong>高速</strong> — 静的生成により First Contentful Paint が最速クラス</li>
              <li class="leading-7"><strong>SEO 対応</strong> — サイトマップ・メタタグを自動生成</li>
              <li class="leading-7"><strong>Notion 記法をフル活用</strong> — コールアウト、トグル、数式、カラム、カラーに対応</li>
              <li class="leading-7"><strong>画像最適化</strong> — Astro の Sharp サービスで WebP 変換・リサイズ</li>
              <li class="leading-7"><strong>キャッシュ効率</strong> — 更新されたページだけを再取得するインクリメンタルビルド</li>
            </ul>
          </section>

          <section class="mb-10">
            <h2 class="mb-4 text-xl font-semibold" style="color: #37352f;">始め方</h2>
            <pre class="overflow-x-auto rounded-lg p-4 font-mono text-sm" style="background: rgba(55,53,47,0.04); border: 1px solid rgba(55,53,47,0.09);"><code style="color: #37352f;">git clone https://github.com/mosugi/notro-tail
npm install
cp .env.example .env  # NOTION_TOKEN, NOTION_DATASOURCE_ID を設定
npm run dev</code></pre>
            <p class="mt-4 text-sm" style="color: rgba(55,53,47,0.55);">
              詳細は <a href="/blog/setup/" class="underline underline-offset-2 hover:opacity-70" style="color: #2383e2;">セットアップガイド</a> をご覧ください。
            </p>
          </section>

          <section>
            <h2 class="mb-4 text-xl font-semibold" style="color: #37352f;">リンク</h2>
            <ul class="space-y-1 pl-6 list-disc text-sm" style="color: rgba(55,53,47,0.65);">
              <li><a href="https://github.com/mosugi/notro-tail" class="underline underline-offset-2 hover:opacity-70" style="color: #2383e2;">GitHub — mosugi/notro-tail</a></li>
              <li><a href="https://www.npmjs.com/package/notro" class="underline underline-offset-2 hover:opacity-70" style="color: #2383e2;">npm — notro</a></li>
              <li><a href="/blog/" class="underline underline-offset-2 hover:opacity-70" style="color: #2383e2;">ブログ（Notion 記事一覧）</a></li>
            </ul>
          </section>
        </>
      )}

    </article>
  </main>
</Layout>
