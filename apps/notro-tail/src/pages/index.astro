---
import Layout from "../layouts/Layout.astro";
---

<Layout title="NotroTail — Notion to Astro static site generator">
  <main class="mx-auto max-w-screen-xl px-4 sm:px-6 lg:px-8">
    <section class="flex min-h-[50vh] items-center justify-center py-20">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl">
          Notion as your CMS.
          <span class="text-blue-600">Astro as your site.</span>
        </h1>

        <p class="mt-6 text-lg leading-8 text-gray-600">
          NotroTail fetches content from Notion via the Public API, renders it
          through MDX with a component mapping, and outputs a fast,
          SEO-optimized static site styled with TailwindCSS 4.
        </p>

        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href="/blog/"
            class="rounded-md bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-500"
          >
            View Blog
          </a>
          <a
            href="https://github.com/mosugi/notro-tail"
            class="rounded-md border border-gray-200 bg-white px-6 py-3 text-sm font-semibold text-gray-900 shadow-sm transition hover:bg-gray-50"
          >
            GitHub
          </a>
        </div>
      </div>
    </section>

    <section class="pb-20">
      <h2 class="mb-8 text-2xl font-bold text-gray-900">Features</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <details open class="rounded-xl border border-gray-100 p-5 shadow-sm transition hover:border-gray-200 hover:shadow">
          <summary class="cursor-pointer text-base"><strong>Notion Content Loader</strong></summary>
          <p class="mt-2 text-sm text-gray-600">
            Astro Content Collections backed by the Notion Public API. Incremental
            builds via <code>last_edited_time</code> cache invalidation.
          </p>
        </details>

        <details open class="rounded-xl border border-gray-100 p-5 shadow-sm transition hover:border-gray-200 hover:shadow">
          <summary class="cursor-pointer text-base"><strong>Component Mapping</strong></summary>
          <p class="mt-2 text-sm text-gray-600">
            Notion blocks rendered as Astro components via MDX evaluate() and a
            component mapping — callouts, columns, toggles, KaTeX math, and more.
          </p>
        </details>

        <details open class="rounded-xl border border-gray-100 p-5 shadow-sm transition hover:border-gray-200 hover:shadow">
          <summary class="cursor-pointer text-base"><strong>TailwindCSS 4</strong></summary>
          <p class="mt-2 text-sm text-gray-600">
            Scoped styles per Notion component. Fast, tree-shaken output with
            per-page theme support via <code>bodyClass</code>.
          </p>
        </details>

        <details open class="rounded-xl border border-gray-100 p-5 shadow-sm transition hover:border-gray-200 hover:shadow">
          <summary class="cursor-pointer text-base"><strong>Optimized Images</strong></summary>
          <p class="mt-2 text-sm text-gray-600">
            Custom Astro image service strips expiring Notion pre-signed S3 query
            parameters so cached images survive across builds.
          </p>
        </details>

        <details open class="rounded-xl border border-gray-100 p-5 shadow-sm transition hover:border-gray-200 hover:shadow">
          <summary class="cursor-pointer text-base"><strong>Paginated Blog</strong></summary>
          <p class="mt-2 text-sm text-gray-600">
            Built-in paginated blog with tag and category filtering, all driven
            from your Notion database.
          </p>
        </details>

        <details open class="rounded-xl border border-gray-100 p-5 shadow-sm transition hover:border-gray-200 hover:shadow">
          <summary class="cursor-pointer text-base"><strong>npm Library</strong></summary>
          <p class="mt-2 text-sm text-gray-600">
            The <code>notro</code> package is published to npm. Drop the loader
            and components into any Astro project.
          </p>
        </details>
      </div>
    </section>
  </main>
</Layout>
