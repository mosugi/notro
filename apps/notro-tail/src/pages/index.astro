---
import Layout from "../layouts/Layout.astro";
---

<style>
  /* ── Hero ───────────────────────────────────────────────────────────────── */
  .hero {
    padding: 5rem 0 5rem;
    text-align: center;
    border-bottom: 1px solid rgba(55, 53, 47, 0.09);
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: #2383e2;
    background: rgba(35, 131, 226, 0.08);
    border: 1px solid rgba(35, 131, 226, 0.2);
    border-radius: 100px;
    padding: 0.25rem 0.75rem;
    margin-bottom: 1.5rem;
  }
  .hero-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: #37352f;
    margin-bottom: 1.25rem;
  }
  .hero-title .accent { color: #2383e2; }
  .hero-description {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(55, 53, 47, 0.65);
    max-width: 560px;
    margin: 0 auto 2rem;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .hero-install {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 0.875rem;
    background: #f7f6f3;
    border: 1px solid rgba(55, 53, 47, 0.12);
    border-radius: 6px;
    padding: 0.5rem 1rem;
    color: rgba(55, 53, 47, 0.7);
  }
  .hero-install span { color: #2383e2; user-select: none; }

  /* ── Buttons ─────────────────────────────────────────────────────────────── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: #2383e2;
    color: #fff;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: 5px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: #37352f;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: 5px;
    border: 1px solid rgba(55, 53, 47, 0.18);
    background: #fff;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .btn-secondary:hover {
    background: rgba(55, 53, 47, 0.03);
    border-color: rgba(55, 53, 47, 0.3);
  }

  /* ── Section common ──────────────────────────────────────────────────────── */
  .section {
    padding: 4rem 0;
    border-bottom: 1px solid rgba(55, 53, 47, 0.09);
  }
  .section:last-child { border-bottom: none; }
  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #2383e2;
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 700;
    color: #37352f;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }
  .section-subtitle {
    font-size: 0.9375rem;
    color: rgba(55, 53, 47, 0.55);
    margin-bottom: 2.5rem;
  }

  /* ── How it works (3 steps) ──────────────────────────────────────────────── */
  .steps {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .steps { grid-template-columns: repeat(3, 1fr); }
  }
  .step {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .step-num {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(35, 131, 226, 0.1);
    color: #2383e2;
    font-size: 0.875rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .step-title {
    font-size: 1rem;
    font-weight: 600;
    color: #37352f;
  }
  .step-desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: rgba(55, 53, 47, 0.6);
  }
  .step-connector {
    display: none;
  }
  @media (min-width: 768px) {
    .step-connector {
      display: flex;
      align-items: flex-start;
      padding-top: 0.9rem;
      color: rgba(55, 53, 47, 0.2);
      font-size: 1.25rem;
    }
  }

  /* ── Features grid ───────────────────────────────────────────────────────── */
  .features {
    display: grid;
    gap: 1px;
    background: rgba(55, 53, 47, 0.09);
    border: 1px solid rgba(55, 53, 47, 0.09);
    border-radius: 8px;
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .features { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .features { grid-template-columns: repeat(3, 1fr); }
  }
  .feature {
    background: #fff;
    padding: 1.5rem;
  }
  .feature-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    margin-bottom: 0.75rem;
    background: rgba(55, 53, 47, 0.04);
  }
  .feature-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #37352f;
    margin-bottom: 0.375rem;
  }
  .feature-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: rgba(55, 53, 47, 0.6);
  }
  .feature-desc code {
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 0.75rem;
    background: rgba(135, 131, 120, 0.15);
    color: #eb5757;
    border-radius: 3px;
    padding: 0.1em 0.3em;
  }

  /* ── Packages ────────────────────────────────────────────────────────────── */
  .packages {
    display: grid;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .packages { grid-template-columns: repeat(3, 1fr); }
  }
  .package-card {
    border: 1px solid rgba(55, 53, 47, 0.09);
    border-radius: 8px;
    padding: 1.25rem;
    background: #fff;
  }
  .package-name {
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 0.875rem;
    font-weight: 600;
    color: #37352f;
    margin-bottom: 0.375rem;
  }
  .package-path {
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 0.6875rem;
    color: rgba(55,53,47,0.4);
    margin-bottom: 0.5rem;
  }
  .package-desc {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: rgba(55, 53, 47, 0.6);
  }
  .package-badge {
    display: inline-block;
    font-size: 0.6875rem;
    background: rgba(35, 131, 226, 0.1);
    color: #2383e2;
    border-radius: 3px;
    padding: 0.1rem 0.4rem;
    margin-bottom: 0.5rem;
  }

  /* ── CTA ─────────────────────────────────────────────────────────────────── */
  .cta {
    text-align: center;
    padding: 3.5rem 1.5rem;
    background: rgba(35, 131, 226, 0.04);
    border: 1px solid rgba(35, 131, 226, 0.12);
    border-radius: 10px;
  }
  .cta-title {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #37352f;
    margin-bottom: 0.5rem;
  }
  .cta-desc {
    font-size: 0.9375rem;
    color: rgba(55, 53, 47, 0.6);
    margin-bottom: 1.75rem;
  }
</style>

<Layout
  title="NotroTail — Notion を CMS として使う Astro 静的サイトジェネレーター"
  description="Notion Public API からコンテンツを取得し、MDX としてコンパイル。Notion のブロックを Astro コンポーネントにマッピングして高速・SEO 最適化された静的サイトを生成します。"
>
  <main id="main-content" class="mx-auto max-w-screen-xl px-4 sm:px-6 lg:px-8">

    <!-- Hero -->
    <section class="hero">
      <div class="hero-badge">
        <span>⚡</span>
        <span>Notion × Astro × TailwindCSS 4</span>
      </div>
      <h1 class="hero-title">
        Notion をそのまま CMS に。<br />
        <span class="accent">Astro で高速静的サイトへ。</span>
      </h1>
      <p class="hero-description">
        Notion Public API からコンテンツを取得し、MDX としてコンパイル。
        Notion のブロックを Astro コンポーネントにマッピングして
        高速・SEO 最適化された静的サイトを生成します。
      </p>
      <div class="hero-actions">
        <a href="/blog/" class="btn-primary">ブログを見る →</a>
        <a href="https://github.com/mosugi/notro-tail" target="_blank" rel="noopener noreferrer" class="btn-secondary">
          GitHub で見る
        </a>
      </div>
      <div>
        <code class="hero-install">
          <span>$</span> npm install notro
        </code>
      </div>
    </section>

    <!-- How it works -->
    <section class="section">
      <p class="section-label">使い方</p>
      <h2 class="section-title">3 ステップで始められる</h2>
      <p class="section-subtitle">Notion にコンテンツを書いて、コマンド一つでデプロイ</p>

      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <p class="step-title">Notion でコンテンツを書く</p>
          <p class="step-desc">
            Notion データベースに記事を追加するだけ。
            コールアウト・数式・テーブルなど、Notion のリッチブロックをそのまま使えます。
          </p>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <p class="step-title">notro がビルド時に取得・変換</p>
          <p class="step-desc">
            <code>notro</code> Content Loader が Notion API から Markdown を取得。
            <code>last_edited_time</code> によるキャッシュで差分ビルドを実現します。
          </p>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <p class="step-title">Astro が静的サイトを生成</p>
          <p class="step-desc">
            MDX として評価された Notion ブロックが Astro コンポーネントに変換され、
            高速な静的 HTML として配信されます。
          </p>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="section">
      <p class="section-label">機能</p>
      <h2 class="section-title">必要なものがすべて揃っている</h2>
      <p class="section-subtitle">Notion をヘッドレス CMS として使うためのフルスタック構成</p>
      <div class="features">
        <div class="feature">
          <div class="feature-icon">📦</div>
          <p class="feature-title">Notion Content Loader</p>
          <p class="feature-desc">
            Astro Content Collections を Notion Public API で動かす。
            <code>last_edited_time</code> による差分ビルドで高速なインクリメンタルビルドを実現。
          </p>
        </div>
        <div class="feature">
          <div class="feature-icon">🧩</div>
          <p class="feature-title">コンポーネントマッピング</p>
          <p class="feature-desc">
            コールアウト・カラム・トグル・KaTeX 数式など、Notion ブロックを
            MDX <code>evaluate()</code> + コンポーネントマッピングで Astro コンポーネントに変換。
          </p>
        </div>
        <div class="feature">
          <div class="feature-icon">🎨</div>
          <p class="feature-title">TailwindCSS 4</p>
          <p class="feature-desc">
            Notion コンポーネントごとにスコープされたスタイル。
            <code>classMap</code> prop でクラス上書き、<code>bodyClass</code> でページ別テーマに対応。
          </p>
        </div>
        <div class="feature">
          <div class="feature-icon">🖼️</div>
          <p class="feature-title">画像の最適化</p>
          <p class="feature-desc">
            Notion の期限付き S3 プリサインド URL から <code>X-Amz-*</code> パラメーターを除去し、
            ビルド間でキャッシュを再利用するカスタム Astro 画像サービス。
          </p>
        </div>
        <div class="feature">
          <div class="feature-icon">📄</div>
          <p class="feature-title">ページネーション付きブログ</p>
          <p class="feature-desc">
            タグ・カテゴリフィルタリング対応の多ページブログ。
            ピン留め投稿・前後記事ナビゲーションもすぐに使えます。
          </p>
        </div>
        <div class="feature">
          <div class="feature-icon">📚</div>
          <p class="feature-title">npm ライブラリとして公開</p>
          <p class="feature-desc">
            <code>notro</code> パッケージを任意の Astro プロジェクトに追加するだけ。
            ローダーとコンポーネントをドロップインで利用できます。
          </p>
        </div>
      </div>
    </section>

    <!-- Packages -->
    <section class="section">
      <p class="section-label">モノレポ構成</p>
      <h2 class="section-title">3 パッケージで責務を分割</h2>
      <p class="section-subtitle">それぞれ独立して利用・公開できる設計</p>
      <div class="packages">
        <div class="package-card">
          <span class="package-badge">npm</span>
          <p class="package-name">remark-nfm</p>
          <p class="package-path">packages/remark-nfm/</p>
          <p class="package-desc">
            Notion Flavored Markdown 用の純粋な remark プラグイン。
            前処理・<code>:::callout</code> ディレクティブ・コールアウト変換をまとめて担当。
            Astro や Notion API に依存せず単独で npm 公開可能。
          </p>
        </div>
        <div class="package-card">
          <span class="package-badge">npm</span>
          <p class="package-name">notro</p>
          <p class="package-path">packages/notro/</p>
          <p class="package-desc">
            公開 npm ライブラリ本体。Astro Content Loader + MDX コンパイルパイプライン +
            Notion ブロックコンポーネントを提供。<code>remark-nfm</code> を内部で利用。
          </p>
        </div>
        <div class="package-card">
          <span class="package-badge">template</span>
          <p class="package-name">notro-tail</p>
          <p class="package-path">apps/notro-tail/</p>
          <p class="package-desc">
            デプロイ可能な Astro 6 ウェブサイト。
            <code>notro</code> の実装例として、ブログ・固定ページ・タグフィルタを含むテンプレート。
          </p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section">
      <div class="cta">
        <p class="cta-title">今すぐ始める</p>
        <p class="cta-desc">このリポジトリをテンプレートにして、Notion で書き、Astro でデプロイ。</p>
        <div class="hero-actions" style="justify-content: center;">
          <a href="https://github.com/mosugi/notro-tail" target="_blank" rel="noopener noreferrer" class="btn-primary">
            GitHub で使い方を見る →
          </a>
          <a href="/blog/" class="btn-secondary">デモブログを見る</a>
        </div>
      </div>
    </section>

  </main>
</Layout>
