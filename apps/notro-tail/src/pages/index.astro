---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/widgets/Hero.astro";
import UseCases from "../components/widgets/UseCases.astro";
import HowItWorks from "../components/widgets/HowItWorks.astro";
import Features from "../components/widgets/Features.astro";
import Packages from "../components/widgets/Packages.astro";
import CTA from "../components/widgets/CTA.astro";
---

<Layout
  title="NotroTail — Notion を CMS として使う Astro 静的サイトジェネレーター"
  description="Notion を CMS として使う Astro 静的サイトジェネレーター。"
>
  <main id="main-content" class="mx-auto max-w-screen-xl px-4 sm:px-6 lg:px-8">
    <Hero />
    <UseCases />
    <HowItWorks />
    <Features />
    <Packages />
    <CTA />
  </main>
</Layout>
