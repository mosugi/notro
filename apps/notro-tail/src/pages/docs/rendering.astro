---
// Rendering verification page: showcases all Notion block types rendered via NotionMarkdownRenderer.
import DocsLayout from "../../layouts/DocsLayout.astro";
import { NotionMarkdownRenderer } from "notro";
import Callout from "../../components/notion/Callout.astro";

// Shared classMap matching the blog post renderer
const classMap = {
  callout:     "flex items-start gap-3 my-4 rounded-md p-4",
  toggle:      "my-1",
  toggleTitle: "cursor-pointer select-none py-1 font-medium",
  columns:     "grid grid-cols-1 gap-8 my-4 md:grid-cols-2",
  column:      "min-w-0",
  quote:       "my-4 border-l-[3px] pl-4 italic",
  h1:          "mb-3 mt-10 text-[1.875rem] font-bold tracking-tight",
  h2:          "mb-2 mt-8 text-2xl font-semibold tracking-tight",
  h3:          "mb-2 mt-6 text-xl font-semibold",
  h4:          "mb-1 mt-4 text-base font-semibold",
  image:       "my-4",
  tableWrapper:"my-4 w-full overflow-x-auto",
  table:       "w-full border-collapse text-sm",
  tableCell:   "px-3 py-2 text-sm",
  toc:         "my-4 rounded-md p-4 text-sm",
  p:           "mb-4 leading-7",
  ul:          "mb-4 list-disc pl-6 space-y-1",
  ol:          "mb-4 list-decimal pl-6 space-y-1",
  li:          "leading-7",
  pre:         "my-4 overflow-x-auto rounded-md p-4 font-mono text-sm",
  hr:          "my-8",
  a:           "underline underline-offset-2 hover:opacity-70",
  strong:      "font-semibold",
  em:          "italic",
  del:         "line-through",
  th:          "px-3 py-2 text-left text-sm font-semibold",
} as const;

// --- Markdown samples for each block type ---

const mdHeadings = `# 見出し 1（H1）

## 見出し 2（H2）

### 見出し 3（H3）

#### 見出し 4（H4）

通常の段落テキスト。Notion の見出しブロックは H1〜H4 に対応しています。`;

const mdText = `通常の段落（paragraph）です。**太字**・*斜体*・~~取り消し線~~・\`インラインコード\` が使えます。

[リンクテキスト](https://github.com/mosugi/notro-tail)もサポートしています。`;

const mdLists = `**箇条書きリスト（Bullet list）**

- アイテム 1
- アイテム 2
  - ネストされたアイテム 2-1
  - ネストされたアイテム 2-2
- アイテム 3

**番号付きリスト（Numbered list）**

1. 最初のステップ
2. 次のステップ
   1. サブステップ 2-1
   2. サブステップ 2-2
3. 最後のステップ

**タスクリスト（To-do）**

- [x] 完了したタスク
- [x] これも完了
- [ ] 未完了のタスク
- [ ] もう一つの未完了タスク`;

const mdCallout = `:::callout{color="blue_background"}
💡 **情報コールアウト（blue）**

これはコールアウトブロックです。Notion のコールアウトが
\`:::callout{color="..."}\` ディレクティブ構文に変換されます。
:::

:::callout{color="yellow_background"}
⚠️ **警告コールアウト（yellow）**

色付きのコールアウトも表示できます。
:::

:::callout{color="red_background"}
🚨 **エラーコールアウト（red）**

コールアウト内に複数の段落を含めることもできます。

詳細情報はこちらを参照してください。
:::`;

const mdToggle = `<details class="nt-toggle-block">
<summary class="nt-toggle-block__title">トグルブロック — クリックで展開</summary>

トグルの中身です。このコンテンツは展開時のみ表示されます。

- ネストされたリストも使えます
- アイテム 2

</details>

<details class="nt-toggle-block">
<summary class="nt-toggle-block__title">別のトグル — 折りたたみ例</summary>

長いコンテンツを折りたたむのに便利です。

</details>`;

const mdQuote = `> これは引用ブロック（Blockquote）です。
> Notion の「Quote」ブロックに対応しています。
> 複数行の引用も表示できます。`;

const mdCode = `**JavaScript:**

\`\`\`javascript
// シンタックスハイライト（Shiki）
async function fetchPosts(notion, dbId) {
  const posts = [];
  for await (const page of iteratePaginatedAPI(notion.dataSources.query, {
    data_source_id: dbId,
  })) {
    posts.push(page);
  }
  return posts;
}
\`\`\`

**TypeScript:**

\`\`\`typescript
interface NotionPage {
  id: string;
  properties: {
    Name: { title: RichText[] };
    Slug: { rich_text: RichText[] };
    Public: { checkbox: boolean };
  };
}
\`\`\`

**Bash:**

\`\`\`bash
# ビルドとプレビュー
npm run build
npm run preview --workspace=notro-tail
\`\`\``;

const mdTable = `| ブロックタイプ | Notion 表示 | MDX 出力 |
|---|---|---|
| Paragraph | 普通のテキスト | \`<p>\` |
| Heading 1 | 大見出し | \`<h1>\` |
| Heading 2 | 中見出し | \`<h2>\` |
| Heading 3 | 小見出し | \`<h3>\` |
| Bulleted list | 箇条書き | \`<ul><li>\` |
| Numbered list | 番号付き | \`<ol><li>\` |
| Toggle | 折りたたみ | \`<details>\` |
| Quote | 引用 | \`<blockquote>\` |
| Code | コード | \`<pre><code>\` |
| Callout | コールアウト | \`<callout>\` |`;

const mdMath = `インライン数式: $E = mc^2$ や $\\sum_{i=1}^n x_i$ が書けます。

ブロック数式（KaTeX）:

$$
\\int_{-\\infty}^{\\infty} e^{-x^2} dx = \\sqrt{\\pi}
$$

$$
\\frac{d}{dx}\\left( \\int_{0}^{x} f(u)\\,du\\right) = f(x)
$$`;

const mdHr = `---`;

const mdColumns = `<columns>
<column>

**左カラム**

カラムレイアウト（2カラム）の左側です。
Notion の「Columns」ブロックに対応しています。

- 左側のリスト 1
- 左側のリスト 2

</column>
<column>

**右カラム**

カラムレイアウトの右側です。
モバイルでは縦積みになります。

1. 右側の番号リスト 1
2. 右側の番号リスト 2

</column>
</columns>`;

// Color names and their .nt-color-* CSS classes (defined in global.css).
// Note: raw HTML <span color="..."> / <h2 color="..."> in markdown does NOT trigger
// MDX component mapping (StyledSpan / H2) because MDX only maps components for
// elements from markdown syntax or MDX JSX, not from raw HTML processed by rehype-raw.
// In actual Notion content, colored spans come from Notion's rich-text API output
// which travels through the correct pipeline.
const TEXT_COLORS = [
  { name: "gray",   cls: "nt-color-gray" },
  { name: "brown",  cls: "nt-color-brown" },
  { name: "orange", cls: "nt-color-orange" },
  { name: "yellow", cls: "nt-color-yellow" },
  { name: "green",  cls: "nt-color-green" },
  { name: "blue",   cls: "nt-color-blue" },
  { name: "purple", cls: "nt-color-purple" },
  { name: "pink",   cls: "nt-color-pink" },
  { name: "red",    cls: "nt-color-red" },
] as const;

const BG_COLORS = [
  { name: "gray_background",   cls: "nt-color-gray_background" },
  { name: "brown_background",  cls: "nt-color-brown_background" },
  { name: "orange_background", cls: "nt-color-orange_background" },
  { name: "yellow_background", cls: "nt-color-yellow_background" },
  { name: "green_background",  cls: "nt-color-green_background" },
  { name: "blue_background",   cls: "nt-color-blue_background" },
  { name: "purple_background", cls: "nt-color-purple_background" },
  { name: "pink_background",   cls: "nt-color-pink_background" },
  { name: "red_background",    cls: "nt-color-red_background" },
] as const;
---

<DocsLayout
  title="レンダリング検証 — Docs — NotroTail"
  description="NotionMarkdownRenderer で Notion の全ブロックタイプをレンダリングした実例。"
  heading="レンダリング検証"
>
  <p class="mb-8 text-[rgba(55,53,47,0.65)] dark:text-slate-400 leading-7">
    Notion の各ブロックタイプを <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">NotionMarkdownRenderer</code>
    で実際にレンダリングした例です。
    各セクションにはレンダリング結果とソースの Markdown を並べて表示しています。
  </p>

  <!-- Heading blocks -->
  <section class="mb-12" id="headings">
    <h2 class="mb-1 text-lg font-semibold text-[#37352f] dark:text-slate-100">見出し（Heading）</h2>
    <p class="mb-4 text-sm text-[rgba(55,53,47,0.55)] dark:text-slate-400">H1・H2・H3・H4 の4階層に対応</p>
    <div class="rounded-lg border border-[rgba(55,53,47,0.09)] dark:border-white/8 overflow-hidden">
      <div class="px-5 py-4 nt-markdown-content">
        <NotionMarkdownRenderer markdown={mdHeadings} classMap={classMap} />
      </div>
      <details class="border-t border-[rgba(55,53,47,0.06)] dark:border-white/6">
        <summary class="cursor-pointer select-none px-5 py-2.5 text-xs font-medium text-[rgba(55,53,47,0.5)] dark:text-slate-500 hover:text-[rgba(55,53,47,0.8)] dark:hover:text-slate-300 transition-colors">
          Markdown ソースを表示
        </summary>
        <pre class="m-0 border-t border-[rgba(55,53,47,0.06)] dark:border-white/6 bg-[rgba(55,53,47,0.03)] dark:bg-slate-800/50 px-5 py-4 text-xs font-mono overflow-x-auto text-[rgba(55,53,47,0.7)] dark:text-slate-400">{mdHeadings}</pre>
      </details>
    </div>
  </section>

  <!-- Paragraph and inline styles -->
  <section class="mb-12" id="text">
    <h2 class="mb-1 text-lg font-semibold text-[#37352f] dark:text-slate-100">テキスト・インラインスタイル</h2>
    <p class="mb-4 text-sm text-[rgba(55,53,47,0.55)] dark:text-slate-400">太字・斜体・取り消し線・インラインコード・リンク</p>
    <div class="rounded-lg border border-[rgba(55,53,47,0.09)] dark:border-white/8 overflow-hidden">
      <div class="px-5 py-4 nt-markdown-content">
        <NotionMarkdownRenderer markdown={mdText} classMap={classMap} />
      </div>
      <details class="border-t border-[rgba(55,53,47,0.06)] dark:border-white/6">
        <summary class="cursor-pointer select-none px-5 py-2.5 text-xs font-medium text-[rgba(55,53,47,0.5)] dark:text-slate-500 hover:text-[rgba(55,53,47,0.8)] dark:hover:text-slate-300 transition-colors">
          Markdown ソースを表示
        </summary>
        <pre class="m-0 border-t border-[rgba(55,53,47,0.06)] dark:border-white/6 bg-[rgba(55,53,47,0.03)] dark:bg-slate-800/50 px-5 py-4 text-xs font-mono overflow-x-auto text-[rgba(55,53,47,0.7)] dark:text-slate-400">{mdText}</pre>
      </details>
    </div>
  </section>

  <!-- Lists -->
  <section class="mb-12" id="lists">
    <h2 class="mb-1 text-lg font-semibold text-[#37352f] dark:text-slate-100">リスト（Lists）</h2>
    <p class="mb-4 text-sm text-[rgba(55,53,47,0.55)] dark:text-slate-400">箇条書き・番号付き・タスクリスト（ネスト対応）</p>
    <div class="rounded-lg border border-[rgba(55,53,47,0.09)] dark:border-white/8 overflow-hidden">
      <div class="px-5 py-4 nt-markdown-content">
        <NotionMarkdownRenderer markdown={mdLists} classMap={classMap} />
      </div>
      <details class="border-t border-[rgba(55,53,47,0.06)] dark:border-white/6">
        <summary class="cursor-pointer select-none px-5 py-2.5 text-xs font-medium text-[rgba(55,53,47,0.5)] dark:text-slate-500 hover:text-[rgba(55,53,47,0.8)] dark:hover:text-slate-300 transition-colors">
          Markdown ソースを表示
        </summary>
        <pre class="m-0 border-t border-[rgba(55,53,47,0.06)] dark:border-white/6 bg-[rgba(55,53,47,0.03)] dark:bg-slate-800/50 px-5 py-4 text-xs font-mono overflow-x-auto text-[rgba(55,53,47,0.7)] dark:text-slate-400">{mdLists}</pre>
      </details>
    </div>
  </section>

  <!-- Callout -->
  <section class="mb-12" id="callout">
    <h2 class="mb-1 text-lg font-semibold text-[#37352f] dark:text-slate-100">コールアウト（Callout）</h2>
    <p class="mb-4 text-sm text-[rgba(55,53,47,0.55)] dark:text-slate-400">色付きコールアウトブロック。<code class="font-mono text-[#eb5757] text-[85%]">:::callout{"{color=\"...\"}"}</code> ディレクティブ構文</p>
    <div class="rounded-lg border border-[rgba(55,53,47,0.09)] dark:border-white/8 overflow-hidden">
      <div class="px-5 py-4 nt-markdown-content">
        <NotionMarkdownRenderer markdown={mdCallout} classMap={classMap} components={{ callout: Callout }} />
      </div>
      <details class="border-t border-[rgba(55,53,47,0.06)] dark:border-white/6">
        <summary class="cursor-pointer select-none px-5 py-2.5 text-xs font-medium text-[rgba(55,53,47,0.5)] dark:text-slate-500 hover:text-[rgba(55,53,47,0.8)] dark:hover:text-slate-300 transition-colors">
          Markdown ソースを表示
        </summary>
        <pre class="m-0 border-t border-[rgba(55,53,47,0.06)] dark:border-white/6 bg-[rgba(55,53,47,0.03)] dark:bg-slate-800/50 px-5 py-4 text-xs font-mono overflow-x-auto text-[rgba(55,53,47,0.7)] dark:text-slate-400">{mdCallout}</pre>
      </details>
    </div>
  </section>

  <!-- Toggle -->
  <section class="mb-12" id="toggle">
    <h2 class="mb-1 text-lg font-semibold text-[#37352f] dark:text-slate-100">トグル（Toggle）</h2>
    <p class="mb-4 text-sm text-[rgba(55,53,47,0.55)] dark:text-slate-400">折りたたみ可能なブロック。<code class="font-mono text-[#eb5757] text-[85%]">&lt;details&gt;</code> + CSS アニメーション</p>
    <div class="rounded-lg border border-[rgba(55,53,47,0.09)] dark:border-white/8 overflow-hidden">
      <div class="px-5 py-4 nt-markdown-content">
        <NotionMarkdownRenderer markdown={mdToggle} classMap={classMap} />
      </div>
      <details class="border-t border-[rgba(55,53,47,0.06)] dark:border-white/6">
        <summary class="cursor-pointer select-none px-5 py-2.5 text-xs font-medium text-[rgba(55,53,47,0.5)] dark:text-slate-500 hover:text-[rgba(55,53,47,0.8)] dark:hover:text-slate-300 transition-colors">
          Markdown ソースを表示
        </summary>
        <pre class="m-0 border-t border-[rgba(55,53,47,0.06)] dark:border-white/6 bg-[rgba(55,53,47,0.03)] dark:bg-slate-800/50 px-5 py-4 text-xs font-mono overflow-x-auto text-[rgba(55,53,47,0.7)] dark:text-slate-400">{mdToggle}</pre>
      </details>
    </div>
  </section>

  <!-- Quote -->
  <section class="mb-12" id="quote">
    <h2 class="mb-1 text-lg font-semibold text-[#37352f] dark:text-slate-100">引用（Quote）</h2>
    <p class="mb-4 text-sm text-[rgba(55,53,47,0.55)] dark:text-slate-400">Notion の Quote ブロック → <code class="font-mono text-[#eb5757] text-[85%]">&lt;blockquote&gt;</code></p>
    <div class="rounded-lg border border-[rgba(55,53,47,0.09)] dark:border-white/8 overflow-hidden">
      <div class="px-5 py-4 nt-markdown-content">
        <NotionMarkdownRenderer markdown={mdQuote} classMap={classMap} />
      </div>
      <details class="border-t border-[rgba(55,53,47,0.06)] dark:border-white/6">
        <summary class="cursor-pointer select-none px-5 py-2.5 text-xs font-medium text-[rgba(55,53,47,0.5)] dark:text-slate-500 hover:text-[rgba(55,53,47,0.8)] dark:hover:text-slate-300 transition-colors">
          Markdown ソースを表示
        </summary>
        <pre class="m-0 border-t border-[rgba(55,53,47,0.06)] dark:border-white/6 bg-[rgba(55,53,47,0.03)] dark:bg-slate-800/50 px-5 py-4 text-xs font-mono overflow-x-auto text-[rgba(55,53,47,0.7)] dark:text-slate-400">{mdQuote}</pre>
      </details>
    </div>
  </section>

  <!-- Code blocks -->
  <section class="mb-12" id="code">
    <h2 class="mb-1 text-lg font-semibold text-[#37352f] dark:text-slate-100">コードブロック（Code）</h2>
    <p class="mb-4 text-sm text-[rgba(55,53,47,0.55)] dark:text-slate-400">Shiki によるシンタックスハイライト。JavaScript・TypeScript・Bash など多数の言語に対応</p>
    <div class="rounded-lg border border-[rgba(55,53,47,0.09)] dark:border-white/8 overflow-hidden">
      <div class="px-5 py-4 nt-markdown-content">
        <NotionMarkdownRenderer markdown={mdCode} classMap={classMap} />
      </div>
      <details class="border-t border-[rgba(55,53,47,0.06)] dark:border-white/6">
        <summary class="cursor-pointer select-none px-5 py-2.5 text-xs font-medium text-[rgba(55,53,47,0.5)] dark:text-slate-500 hover:text-[rgba(55,53,47,0.8)] dark:hover:text-slate-300 transition-colors">
          Markdown ソースを表示
        </summary>
        <pre class="m-0 border-t border-[rgba(55,53,47,0.06)] dark:border-white/6 bg-[rgba(55,53,47,0.03)] dark:bg-slate-800/50 px-5 py-4 text-xs font-mono overflow-x-auto text-[rgba(55,53,47,0.7)] dark:text-slate-400">{mdCode}</pre>
      </details>
    </div>
  </section>

  <!-- Table -->
  <section class="mb-12" id="table">
    <h2 class="mb-1 text-lg font-semibold text-[#37352f] dark:text-slate-100">テーブル（Table）</h2>
    <p class="mb-4 text-sm text-[rgba(55,53,47,0.55)] dark:text-slate-400">GFM テーブル記法。ヘッダー行・罫線スタイル付き</p>
    <div class="rounded-lg border border-[rgba(55,53,47,0.09)] dark:border-white/8 overflow-hidden">
      <div class="px-5 py-4 nt-markdown-content">
        <NotionMarkdownRenderer markdown={mdTable} classMap={classMap} />
      </div>
      <details class="border-t border-[rgba(55,53,47,0.06)] dark:border-white/6">
        <summary class="cursor-pointer select-none px-5 py-2.5 text-xs font-medium text-[rgba(55,53,47,0.5)] dark:text-slate-500 hover:text-[rgba(55,53,47,0.8)] dark:hover:text-slate-300 transition-colors">
          Markdown ソースを表示
        </summary>
        <pre class="m-0 border-t border-[rgba(55,53,47,0.06)] dark:border-white/6 bg-[rgba(55,53,47,0.03)] dark:bg-slate-800/50 px-5 py-4 text-xs font-mono overflow-x-auto text-[rgba(55,53,47,0.7)] dark:text-slate-400">{mdTable}</pre>
      </details>
    </div>
  </section>

  <!-- Math -->
  <section class="mb-12" id="math">
    <h2 class="mb-1 text-lg font-semibold text-[#37352f] dark:text-slate-100">数式（Math / KaTeX）</h2>
    <p class="mb-4 text-sm text-[rgba(55,53,47,0.55)] dark:text-slate-400">インライン <code class="font-mono text-[#eb5757] text-[85%]">$...$</code> とブロック <code class="font-mono text-[#eb5757] text-[85%]">$$...$$</code> 数式を KaTeX でレンダリング</p>
    <div class="rounded-lg border border-[rgba(55,53,47,0.09)] dark:border-white/8 overflow-hidden">
      <div class="px-5 py-4 nt-markdown-content">
        <NotionMarkdownRenderer markdown={mdMath} classMap={classMap} />
      </div>
      <details class="border-t border-[rgba(55,53,47,0.06)] dark:border-white/6">
        <summary class="cursor-pointer select-none px-5 py-2.5 text-xs font-medium text-[rgba(55,53,47,0.5)] dark:text-slate-500 hover:text-[rgba(55,53,47,0.8)] dark:hover:text-slate-300 transition-colors">
          Markdown ソースを表示
        </summary>
        <pre class="m-0 border-t border-[rgba(55,53,47,0.06)] dark:border-white/6 bg-[rgba(55,53,47,0.03)] dark:bg-slate-800/50 px-5 py-4 text-xs font-mono overflow-x-auto text-[rgba(55,53,47,0.7)] dark:text-slate-400">{mdMath}</pre>
      </details>
    </div>
  </section>

  <!-- Divider -->
  <section class="mb-12" id="divider">
    <h2 class="mb-1 text-lg font-semibold text-[#37352f] dark:text-slate-100">区切り線（Divider）</h2>
    <p class="mb-4 text-sm text-[rgba(55,53,47,0.55)] dark:text-slate-400">Notion の Divider ブロック → <code class="font-mono text-[#eb5757] text-[85%]">&lt;hr&gt;</code></p>
    <div class="rounded-lg border border-[rgba(55,53,47,0.09)] dark:border-white/8 overflow-hidden">
      <div class="px-5 py-4 nt-markdown-content">
        <NotionMarkdownRenderer markdown={mdHr} classMap={classMap} />
      </div>
      <details class="border-t border-[rgba(55,53,47,0.06)] dark:border-white/6">
        <summary class="cursor-pointer select-none px-5 py-2.5 text-xs font-medium text-[rgba(55,53,47,0.5)] dark:text-slate-500 hover:text-[rgba(55,53,47,0.8)] dark:hover:text-slate-300 transition-colors">
          Markdown ソースを表示
        </summary>
        <pre class="m-0 border-t border-[rgba(55,53,47,0.06)] dark:border-white/6 bg-[rgba(55,53,47,0.03)] dark:bg-slate-800/50 px-5 py-4 text-xs font-mono overflow-x-auto text-[rgba(55,53,47,0.7)] dark:text-slate-400">{mdHr}</pre>
      </details>
    </div>
  </section>

  <!-- Columns -->
  <section class="mb-12" id="columns">
    <h2 class="mb-1 text-lg font-semibold text-[#37352f] dark:text-slate-100">カラムレイアウト（Columns）</h2>
    <p class="mb-4 text-sm text-[rgba(55,53,47,0.55)] dark:text-slate-400">2カラムレイアウト。モバイルでは縦積み</p>
    <div class="rounded-lg border border-[rgba(55,53,47,0.09)] dark:border-white/8 overflow-hidden">
      <div class="px-5 py-4 nt-markdown-content">
        <NotionMarkdownRenderer markdown={mdColumns} classMap={classMap} />
      </div>
      <details class="border-t border-[rgba(55,53,47,0.06)] dark:border-white/6">
        <summary class="cursor-pointer select-none px-5 py-2.5 text-xs font-medium text-[rgba(55,53,47,0.5)] dark:text-slate-500 hover:text-[rgba(55,53,47,0.8)] dark:hover:text-slate-300 transition-colors">
          Markdown ソースを表示
        </summary>
        <pre class="m-0 border-t border-[rgba(55,53,47,0.06)] dark:border-white/6 bg-[rgba(55,53,47,0.03)] dark:bg-slate-800/50 px-5 py-4 text-xs font-mono overflow-x-auto text-[rgba(55,53,47,0.7)] dark:text-slate-400">{mdColumns}</pre>
      </details>
    </div>
  </section>

  <!-- Color annotations -->
  <section class="mb-12" id="colors">
    <h2 class="mb-1 text-lg font-semibold text-[#37352f] dark:text-slate-100">カラーアノテーション（Color Annotations）</h2>
    <p class="mb-4 text-sm text-[rgba(55,53,47,0.55)] dark:text-slate-400">
      Notion の色アノテーションは <code class="font-mono text-[#eb5757] text-[85%]">.nt-color-*</code> CSS クラスで実装。
      テキストカラーは <code class="font-mono text-[#eb5757] text-[85%]">StyledSpan.astro</code>、
      見出しカラーは <code class="font-mono text-[#eb5757] text-[85%]">H1〜H4.astro</code> が <code class="font-mono text-[#eb5757] text-[85%]">colorToClass()</code> で適用。
    </p>
    <div class="rounded-lg border border-[rgba(55,53,47,0.09)] dark:border-white/8 overflow-hidden">
      <div class="px-5 py-5 space-y-5">

        <!-- Text colors -->
        <div>
          <p class="mb-2 text-xs font-semibold text-[rgba(55,53,47,0.45)] dark:text-slate-500 uppercase tracking-wider">テキストカラー</p>
          <div class="flex flex-wrap gap-2">
            {TEXT_COLORS.map(({ name, cls }) => (
              <span class:list={["text-sm font-medium", cls]}>{name}</span>
            ))}
          </div>
        </div>

        <!-- Background colors -->
        <div>
          <p class="mb-2 text-xs font-semibold text-[rgba(55,53,47,0.45)] dark:text-slate-500 uppercase tracking-wider">バックグラウンドカラー</p>
          <div class="flex flex-wrap gap-2">
            {BG_COLORS.map(({ name, cls }) => (
              <span class:list={["text-sm px-2 py-0.5 rounded", cls]}>{name}</span>
            ))}
          </div>
        </div>

        <!-- CSS class table -->
        <details>
          <summary class="cursor-pointer select-none text-xs font-medium text-[rgba(55,53,47,0.5)] dark:text-slate-500 hover:text-[rgba(55,53,47,0.8)] dark:hover:text-slate-300 transition-colors">
            CSS クラス一覧を表示
          </summary>
          <div class="mt-3 overflow-x-auto rounded border border-[rgba(55,53,47,0.06)] dark:border-white/6">
            <table class="w-full text-xs">
              <thead class="bg-[rgba(55,53,47,0.03)] dark:bg-white/3 text-left text-[rgba(55,53,47,0.55)] dark:text-slate-500">
                <tr>
                  <th class="px-3 py-2 font-semibold">CSS クラス</th>
                  <th class="px-3 py-2 font-semibold">CSS 変数</th>
                  <th class="px-3 py-2 font-semibold">適用先</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-[rgba(55,53,47,0.04)] dark:divide-white/4 text-[rgba(55,53,47,0.7)] dark:text-slate-400">
                {TEXT_COLORS.map(({ name, cls }) => (
                  <tr>
                    <td class="px-3 py-1.5"><code class="font-mono">.{cls}</code></td>
                    <td class="px-3 py-1.5"><code class="font-mono">--nt-color-{name}</code></td>
                    <td class="px-3 py-1.5">span・見出しのテキスト色</td>
                  </tr>
                ))}
                {BG_COLORS.map(({ name, cls }) => (
                  <tr>
                    <td class="px-3 py-1.5"><code class="font-mono">.{cls}</code></td>
                    <td class="px-3 py-1.5"><code class="font-mono">--nt-color-{name.replace('_', '-')}-bg</code></td>
                    <td class="px-3 py-1.5">span・コールアウトの背景色</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- Mermaid diagrams -->
  <section class="mb-10" id="mermaid">
    <h2 class="mb-3 text-xl font-semibold text-[#37352f] dark:text-slate-100">Mermaid ダイアグラム</h2>
    <p class="mb-4 text-[rgba(55,53,47,0.65)] dark:text-slate-400 leading-7">
      <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">```mermaid</code>
      コードブロックは <a href="https://github.com/lukilabs/beautiful-mermaid" target="_blank" rel="noopener noreferrer" class="text-[#2383e2] underline underline-offset-2 hover:opacity-70">beautiful-mermaid</a>
      を使ってビルド時に SVG へ変換されます。DOM・ブラウザ不要のサーバーサイドレンダリングです。
    </p>
    <div class="space-y-8">
      <!-- Flowchart -->
      <div>
        <p class="mb-3 text-sm font-medium text-[rgba(55,53,47,0.65)] dark:text-slate-400">フローチャート (graph LR)</p>
        <div class="rounded-lg border border-[rgba(55,53,47,0.09)] dark:border-white/8 p-4 bg-[rgba(55,53,47,0.02)] dark:bg-white/2">
          <NotionMarkdownRenderer
            markdown={`\`\`\`mermaid
graph LR
  A[Notion API] --> B[loader]
  B --> C{キャッシュ?}
  C -- ヒット --> D[ストアから返す]
  C -- ミス --> E[Markdown 取得]
  E --> F[preprocessNotionMarkdown]
  F --> G[Content Collection ストア]
  G --> H[NotionMarkdownRenderer]
  H --> I[compileMdxCached]
  I --> J[evaluate MDX]
  J --> K[ページ出力]
\`\`\``}
            classMap={classMap}
          />
        </div>
        <details class="mt-2">
          <summary class="cursor-pointer text-xs text-[rgba(55,53,47,0.45)] dark:text-slate-500 hover:text-[rgba(55,53,47,0.7)] dark:hover:text-slate-400">Markdown ソースを表示</summary>
          <pre class="mt-2 overflow-x-auto rounded bg-[rgba(55,53,47,0.04)] dark:bg-slate-800 p-3 text-xs font-mono text-[rgba(55,53,47,0.7)] dark:text-slate-300 whitespace-pre">{`\`\`\`mermaid
graph LR
  A[Notion API] --> B[loader]
  B --> C{キャッシュ?}
  C -- ヒット --> D[ストアから返す]
  C -- ミス --> E[Markdown 取得]
  E --> F[preprocessNotionMarkdown]
  F --> G[Content Collection ストア]
  G --> H[NotionMarkdownRenderer]
  H --> I[compileMdxCached]
  I --> J[evaluate MDX]
  J --> K[ページ出力]
\`\`\``}</pre>
        </details>
      </div>

      <!-- Sequence diagram -->
      <div>
        <p class="mb-3 text-sm font-medium text-[rgba(55,53,47,0.65)] dark:text-slate-400">シーケンス図 (sequenceDiagram)</p>
        <div class="rounded-lg border border-[rgba(55,53,47,0.09)] dark:border-white/8 p-4 bg-[rgba(55,53,47,0.02)] dark:bg-white/2">
          <NotionMarkdownRenderer
            markdown={`\`\`\`mermaid
sequenceDiagram
  autonumber
  participant Browser
  participant Astro
  participant Notion
  Browser->>Astro: GET /blog/my-post/
  Astro->>Notion: pages.retrieveMarkdown(pageId)
  Notion-->>Astro: { markdown, truncated }
  Astro->>Astro: compileMdxCached(markdown)
  Astro-->>Browser: HTML レスポンス
\`\`\``}
            classMap={classMap}
          />
        </div>
        <details class="mt-2">
          <summary class="cursor-pointer text-xs text-[rgba(55,53,47,0.45)] dark:text-slate-500 hover:text-[rgba(55,53,47,0.7)] dark:hover:text-slate-400">Markdown ソースを表示</summary>
          <pre class="mt-2 overflow-x-auto rounded bg-[rgba(55,53,47,0.04)] dark:bg-slate-800 p-3 text-xs font-mono text-[rgba(55,53,47,0.7)] dark:text-slate-300 whitespace-pre">{`\`\`\`mermaid
sequenceDiagram
  autonumber
  participant Browser
  participant Astro
  participant Notion
  Browser->>Astro: GET /blog/my-post/
  Astro->>Notion: pages.retrieveMarkdown(pageId)
  Notion-->>Astro: { markdown, truncated }
  Astro->>Astro: compileMdxCached(markdown)
  Astro-->>Browser: HTML レスポンス
\`\`\``}</pre>
        </details>
      </div>
    </div>
  </section>
</DocsLayout>
