---
// Customization guide: config.ts, components, styles.
import DocsLayout from "../../layouts/DocsLayout.astro";
---

<DocsLayout
  title="カスタマイズ — Docs — NotroTail"
  description="サイト設定・コンポーネント差し替え・スタイル調整など、NotroTail のカスタマイズ方法を解説します。"
  heading="カスタマイズ"
>
  <p class="mb-8 nt-text-65 dark:text-slate-400 leading-7">
    NotroTail は <strong>Astro ファイルを直接編集する</strong>テンプレートです。
    サイト名・ナビゲーション・フッターは各コンポーネントに直書きされているので、該当箇所を編集するだけです。
    さらにコンポーネントを差し替えたり、スタイルをカスタマイズしたりすることも可能です。
  </p>

  <!-- 1: config.ts -->
  <section class="mb-12" id="config">
    <h2 class="mb-4 text-xl font-semibold nt-text dark:text-slate-100">1. サイト設定（config.ts）</h2>
    <p class="mb-4 nt-text-75 dark:text-slate-300 leading-7">
      <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">src/config.ts</code>
      にはブログのページネーション数とシステムタグのみ定義されています。
      サイト名や説明文は各コンポーネントに直接記述します。
    </p>

    <div class="mb-6 rounded-md border nt-border overflow-hidden dark:border-white/8">
      <div class="nt-bg-04 px-4 py-2 text-xs font-mono nt-text-50 dark:bg-white/4 dark:text-slate-500">src/config.ts</div>
      <pre class="overflow-x-auto p-4 text-sm font-mono bg-white dark:bg-[#0f172a]"><code>{`// 1ページあたりの記事数
export const BLOG_POSTS_PER_PAGE = 10;

// System tags — affect post filtering logic
export const INTERNAL_TAGS = ["page", "pinned"];`}</code></pre>
    </div>
  </section>

  <!-- 2: astro.config.mjs -->
  <section class="mb-12" id="astro-config">
    <h2 class="mb-4 text-xl font-semibold nt-text dark:text-slate-100">2. ビルド設定（astro.config.mjs）</h2>
    <p class="mb-4 nt-text-75 dark:text-slate-300 leading-7">
      サイトの canonical URL は
      <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">astro.config.mjs</code>
      の <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">site</code>
      オプションで設定します。<code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">SeoHead.astro</code> 内の <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">SITE_URL</code> と合わせてください。
    </p>
    <div class="rounded-md border nt-border overflow-hidden dark:border-white/8">
      <div class="nt-bg-04 px-4 py-2 text-xs font-mono nt-text-50 dark:bg-white/4 dark:text-slate-500">astro.config.mjs（抜粋）</div>
      <pre class="overflow-x-auto p-4 text-sm font-mono bg-white dark:bg-[#0f172a]"><code>{`export default defineConfig({
  site: "https://example.com",
  // ...
});`}</code></pre>
    </div>
  </section>

  <!-- 3: Widgets -->
  <section class="mb-12" id="widgets">
    <h2 class="mb-4 text-xl font-semibold nt-text dark:text-slate-100">3. トップページのカスタマイズ（widgets/）</h2>
    <p class="mb-4 nt-text-75 dark:text-slate-300 leading-7">
      トップページ（<code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">src/pages/index.astro</code>）
      は以下の Widget コンポーネントに分割されています。
      不要なセクションは削除し、必要なセクションを追加するだけです。
    </p>
    <div class="rounded-md border nt-border overflow-hidden dark:border-white/8">
      <div class="nt-bg-04 px-4 py-2 text-xs font-mono nt-text-50 dark:bg-white/4 dark:text-slate-500">src/pages/index.astro</div>
      <pre class="overflow-x-auto p-4 text-sm font-mono bg-white dark:bg-[#0f172a]"><code>{`---
import Hero from "../components/widgets/Hero.astro";
import Features from "../components/widgets/Features.astro";
import CTA from "../components/widgets/CTA.astro";
// 不要なものは削除、必要なものだけ残す
---

<Layout ...>
  <main>
    <Hero />       {/* ← tagline や description は props で上書き可能 */}
    <Features />   {/* ← features 配列を props で渡せばカスタム内容に変更可 */}
    <CTA />
  </main>
</Layout>`}</code></pre>
    </div>
    <p class="mt-4 text-sm nt-text-65 dark:text-slate-400 leading-7">
      各 Widget は <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">props</code> でデフォルト値を上書きできます。
      例えば <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">{'<Hero tagline="私のブログへようこそ" />'}</code>
      のように渡すだけでキャッチフレーズを変更できます。
    </p>
  </section>

  <!-- 4: Components -->
  <section class="mb-12" id="components">
    <h2 class="mb-4 text-xl font-semibold nt-text dark:text-slate-100">4. ブログコンポーネントのカスタマイズ</h2>
    <p class="mb-4 nt-text-75 dark:text-slate-300 leading-7">
      ブログ関連のコンポーネントは <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">src/components/blog/</code> にまとめられています。
    </p>
    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="nt-bg-04 dark:bg-white/4">
            <th class="px-4 py-2.5 text-left font-semibold nt-text">ファイル</th>
            <th class="px-4 py-2.5 text-left font-semibold nt-text">役割</th>
          </tr>
        </thead>
        <tbody>
          {[
            ["blog/PostCard.astro", "記事カード（サムネイル・タイトル・日付・タグ）"],
            ["blog/BlogList.astro", "記事カードのグリッドリスト"],
            ["blog/Pagination.astro", "前へ / 次へ ページネーション"],
            ["notion/Callout.astro", "Notion コールアウトブロックの表示"],
          ].map(([file, desc]) => (
            <tr class="border-t nt-border-06 dark:border-white/6">
              <td class="px-4 py-2.5 font-mono text-xs nt-text-75 dark:text-slate-300">{file}</td>
              <td class="px-4 py-2.5 nt-text-75 dark:text-slate-300">{desc}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- 5: Styles -->
  <section class="mb-12" id="styles">
    <h2 class="mb-4 text-xl font-semibold nt-text dark:text-slate-100">5. スタイルのカスタマイズ</h2>
    <p class="mb-4 nt-text-75 dark:text-slate-300 leading-7">
      スタイリングは <strong>TailwindCSS 4 のユーティリティクラスのみ</strong>で行います。
      Notion ブロック固有のスタイルは
      <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">src/styles/global.css</code>
      の <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">nt-*</code> クラスとして定義されています。
    </p>

    <h3 class="mb-2 text-base font-semibold nt-text">classMap で記事スタイルを調整する</h3>
    <p class="mb-4 text-sm nt-text-65 dark:text-slate-400 leading-7">
      Notion コンポーネントのスタイルは
      <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">NotionMarkdownRenderer</code>
      の <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">classMap</code> prop で上書きできます（コンポーネント自体を差し替えずにスタイルだけ変更できます）。
    </p>
    <div class="rounded-md border nt-border overflow-hidden dark:border-white/8">
      <div class="nt-bg-04 px-4 py-2 text-xs font-mono nt-text-50 dark:bg-white/4 dark:text-slate-500">blog/[slug].astro（抜粋）</div>
      <pre class="overflow-x-auto p-4 text-sm font-mono bg-white dark:bg-[#0f172a]"><code>{`<NotionMarkdownRenderer
  markdown={markdown}
  classMap={{
    p:    "mb-4 leading-7",
    h2:   "mb-2 mt-8 text-2xl font-semibold tracking-tight",
    a:    "underline underline-offset-2 hover:opacity-70",
    // ...
  }}
/>`}</code></pre>
    </div>

    <h3 class="mt-6 mb-2 text-base font-semibold nt-text">コンポーネントを完全に差し替える</h3>
    <p class="mb-4 text-sm nt-text-65 dark:text-slate-400 leading-7">
      <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">components</code> prop でコンポーネント自体を置き換えることもできます。
      例えばコールアウトのデザインを完全に変えたい場合：
    </p>
    <div class="rounded-md border nt-border overflow-hidden dark:border-white/8">
      <div class="nt-bg-04 px-4 py-2 text-xs font-mono nt-text-50 dark:bg-white/4 dark:text-slate-500">blog/[slug].astro（抜粋）</div>
      <pre class="overflow-x-auto p-4 text-sm font-mono bg-white dark:bg-[#0f172a]"><code>{`import MyCallout from "../../components/MyCallout.astro";

<NotionMarkdownRenderer
  markdown={markdown}
  components={{ callout: MyCallout }}
/>`}</code></pre>
    </div>
    <p class="mt-3 text-sm nt-text-65 dark:text-slate-400">
      利用可能なすべての override キーは
      <a href="/docs/api-reference/#renderer" class="text-[#2383e2] underline underline-offset-2 hover:opacity-70">API リファレンス</a>
      を参照してください。
    </p>
  </section>

  <!-- 6: Navigation -->
  <section class="mb-12" id="navigation">
    <h2 class="mb-4 text-xl font-semibold nt-text dark:text-slate-100">6. ナビゲーションのカスタマイズ</h2>
    <p class="mb-4 nt-text-75 dark:text-slate-300 leading-7">
      ヘッダーナビは <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">src/components/Header.astro</code>、
      フッターリンクは <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">src/components/Footer.astro</code>
      のフロントマターを直接編集します。
    </p>
    <div class="rounded-md border nt-border overflow-hidden dark:border-white/8">
      <div class="nt-bg-04 px-4 py-2 text-xs font-mono nt-text-50 dark:bg-white/4 dark:text-slate-500">src/components/Header.astro（抜粋）</div>
      <pre class="overflow-x-auto p-4 text-sm font-mono bg-white dark:bg-[#0f172a]"><code>{`const NAV_LINKS = [
  { href: "/blog/", label: "ブログ" },
  { href: "/docs/", label: "Docs" },
  { href: "/about/", label: "About" }, // ← 追加するだけ
];`}</code></pre>
    </div>
    <p class="mt-4 text-sm nt-text-65 dark:text-slate-400 leading-7">
      Notion の固定ページ（<code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">page</code> タグ付き）を
      About や Privacy として使う場合は、Notion 上でその記事の Slug を設定し、
      対応する URL（<code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">/blog/about/</code> など）を
      <code class="bg-[rgba(135,131,120,0.15)] text-[#eb5757] rounded-[3px] px-1.5 py-0.5 text-[85%] font-mono">NAV_LINKS</code> に追加してください。
    </p>
  </section>

</DocsLayout>
