---
import { getCollection } from "astro:content";
import NotionCustomBlocks from "notro/src/components/NotionCustomBlocks.astro";
import Layout from "../layouts/Layout.astro";

export async function getStaticPaths() {
  const collection = await getCollection("database");
  return collection.map((entry) => {
    return {
      params: {
        slug: entry.id,
      },
      props: {
        entry: entry,
      },
    };
  });
}

const { entry } = Astro.props;

const options = {
  optimizeRemoteImage: true,
  useRawHTML: true,
  useCalloutContainer: true,
};
---

<Layout title={entry.id}>
  <h1>{entry.id}</h1>
  <main class="nt-page" id={"page.id"}>
    <NotionCustomBlocks blocks={entry.data.blocks} options={options} />
  </main>
</Layout>
