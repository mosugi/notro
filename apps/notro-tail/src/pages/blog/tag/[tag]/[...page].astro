---
export const prerender = false;

import { getLiveCollection } from "astro:content";
import { getMultiSelect, hasTag } from "notro";
import BlogList from "../../../../components/blog/BlogList.astro";
import Layout from "../../../../layouts/Layout.astro";
import Pagination from "../../../../components/blog/Pagination.astro";
import { INTERNAL_TAGS, BLOG_POSTS_PER_PAGE, SITE_NAME } from "../../../../config";

const { tag } = Astro.params;
const pageParam = Astro.params.page;
const currentPage = pageParam ? parseInt(pageParam as string) : 1;

if (!tag || isNaN(currentPage) || currentPage < 1) {
  return Astro.redirect("/blog/");
}

const result = await getLiveCollection("posts");
const allPosts = result.entries ?? [];

const filteredPosts = allPosts.filter((post) =>
  hasTag(post.data.properties.Tags, tag),
);

const lastPage = Math.max(1, Math.ceil(filteredPosts.length / BLOG_POSTS_PER_PAGE));

if (currentPage > lastPage) {
  return Astro.redirect(`/blog/tag/${tag}/`);
}

const startIdx = (currentPage - 1) * BLOG_POSTS_PER_PAGE;
const pageEntries = filteredPosts.slice(startIdx, startIdx + BLOG_POSTS_PER_PAGE);
const data = pageEntries.map(({ data }) => data);

const prevUrl =
  currentPage > 1
    ? currentPage === 2
      ? `/blog/tag/${tag}/`
      : `/blog/tag/${tag}/${currentPage - 1}/`
    : undefined;
const nextUrl =
  currentPage < lastPage ? `/blog/tag/${tag}/${currentPage + 1}/` : undefined;
---

<Layout title={`タグ: ${tag} — ${SITE_NAME}`} description={`「${tag}」タグの記事一覧`}>
  <main id="main-content" class="mx-auto max-w-screen-xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-8">
      <a href="/blog/" class="mb-3 inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-900">
        ← ブログ一覧
      </a>
      <h1 class="text-3xl font-bold text-gray-900">タグ: {tag}</h1>
    </div>
    <BlogList posts={data} />
    <Pagination
      currentPage={currentPage}
      lastPage={lastPage}
      prevUrl={prevUrl}
      nextUrl={nextUrl}
    />
  </main>
</Layout>
