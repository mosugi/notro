---
import type { PaginateFunction } from "astro";
import { getCollection } from "astro:content";
import { hasTag } from "notro";
import BlogList from "../../components/blog/BlogList.astro";
import Layout from "../../layouts/Layout.astro";
import Pagination from "../../components/blog/Pagination.astro";
import { SITE_NAME, BLOG_POSTS_PER_PAGE, BLOG_TITLE, BLOG_DESCRIPTION, FEATURED_SECTIONS } from "../../config";

export async function getStaticPaths({
  paginate,
}: {
  paginate: PaginateFunction;
}) {
  const allPosts = await getCollection("posts");

  // Posts tagged "page" are fixed pages, excluded from blog listing
  const blogPosts = allPosts.filter((entry) => !hasTag(entry.data.properties.Tags, "page"));

  // Compute posts for each featured section.
  // Each section excludes posts already claimed by earlier sections.
  const featuredSectionsData = FEATURED_SECTIONS.map((section, idx) => {
    const prevTags = FEATURED_SECTIONS.slice(0, idx).map((s) => s.tag);
    return {
      section,
      posts: blogPosts
        .filter(
          (e) =>
            hasTag(e.data.properties.Tags, section.tag) &&
            !prevTags.some((t) => hasTag(e.data.properties.Tags, t)),
        )
        .map(({ data }) => data),
    };
  });

  // Paginate all blogPosts so the total count includes featured posts.
  // Featured posts are filtered out from page.data before rendering to avoid duplication.
  return paginate(blogPosts, {
    pageSize: BLOG_POSTS_PER_PAGE,
    props: { featuredSectionsData },
  });
}

const { page, featuredSectionsData } = Astro.props;

// Tags belonging to any featured section (used to filter the regular list)
const allFeaturedTags = FEATURED_SECTIONS.map((s) => s.tag);

// Exclude featured posts from the regular paginated list to avoid duplication
const data = page.data
  .filter((entry) => !allFeaturedTags.some((t) => hasTag(entry.data.properties.Tags, t)))
  .map(({ data }) => data);
---

<Layout title={`${BLOG_TITLE} — ${SITE_NAME}`} description={BLOG_DESCRIPTION}>
  <main id="main-content" class="mx-auto max-w-screen-xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">{BLOG_TITLE}</h1>
    </div>

    {featuredSectionsData.map(({ section, posts }) => (
      <Fragment>
        {page.currentPage === 1 && posts.length > 0 && (
          <section class="mb-10">
            <h2 class="mb-4 text-lg font-semibold text-gray-700 dark:text-gray-300">{section.heading}</h2>
            <BlogList posts={posts} />
          </section>
        )}
        {page.currentPage > 1 && posts.length > 0 && (
          <p class="mb-6 text-sm text-gray-500 dark:text-gray-400">
            <a href="/blog/" class="text-sky-600 hover:underline dark:text-sky-400">{section.pageHint}</a>
          </p>
        )}
      </Fragment>
    ))}

    <BlogList posts={data} />
    <Pagination
      currentPage={page.currentPage}
      lastPage={page.lastPage}
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
    />
  </main>
</Layout>
