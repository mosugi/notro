---
export const prerender = false;

import { getLiveCollection } from "astro:content";
import { hasTag } from "notro";
import BlogList from "../../components/blog/BlogList.astro";
import Layout from "../../layouts/Layout.astro";
import Pagination from "../../components/blog/Pagination.astro";
import { SITE_NAME, BLOG_POSTS_PER_PAGE } from "../../config";

const pageParam = Astro.params.page;
const currentPage = pageParam ? parseInt(pageParam as string) : 1;

if (isNaN(currentPage) || currentPage < 1) {
  return Astro.redirect("/blog/");
}

const result = await getLiveCollection("posts");
const allPosts = result.entries ?? [];

// Posts tagged "page" are fixed pages, excluded from blog listing
const blogPosts = allPosts
  .filter((e) => !hasTag(e.data.properties.Tags, "page"))
  .sort((a, b) => {
    const dateA = a.data.properties.Date.date?.start ?? "";
    const dateB = b.data.properties.Date.date?.start ?? "";
    return dateB.localeCompare(dateA);
  });

const pinnedPosts = blogPosts.filter((e) =>
  hasTag(e.data.properties.Tags, "pinned"),
);
const beginnerPosts = blogPosts.filter(
  (e) =>
    hasTag(e.data.properties.Tags, "入門") &&
    !hasTag(e.data.properties.Tags, "pinned"),
);

const lastPage = Math.max(1, Math.ceil(blogPosts.length / BLOG_POSTS_PER_PAGE));

if (currentPage > lastPage) {
  return Astro.redirect("/blog/");
}

const startIdx = (currentPage - 1) * BLOG_POSTS_PER_PAGE;
const pageEntries = blogPosts.slice(startIdx, startIdx + BLOG_POSTS_PER_PAGE);

const displayData = pageEntries
  .filter((e) => !hasTag(e.data.properties.Tags, "pinned"))
  .filter((e) => !hasTag(e.data.properties.Tags, "入門"))
  .map(({ data }) => data);

const prevUrl =
  currentPage > 1
    ? currentPage === 2
      ? "/blog/"
      : `/blog/${currentPage - 1}/`
    : undefined;
const nextUrl = currentPage < lastPage ? `/blog/${currentPage + 1}/` : undefined;
---

<Layout title={`ブログ — ${SITE_NAME}`} description="Notion × Astro で作られたブログ。セットアップ・カスタマイズ・デプロイまで、notro の使い方を解説します。">
  <main id="main-content" class="mx-auto max-w-screen-xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">Blog</h1>
    </div>
    {currentPage === 1 && pinnedPosts.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-4 text-lg font-semibold text-gray-700 dark:text-gray-300">ピン留め</h2>
        <BlogList posts={pinnedPosts.map(({ data }) => data)} />
      </section>
    )}
    {currentPage > 1 && pinnedPosts.length > 0 && (
      <p class="mb-6 text-sm text-gray-500 dark:text-gray-400">
        <a href="/blog/" class="text-sky-600 hover:underline dark:text-sky-400">← ピン留め記事</a>は1ページ目にあります
      </p>
    )}
    {currentPage === 1 && beginnerPosts.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-4 text-lg font-semibold text-gray-700 dark:text-gray-300">入門</h2>
        <BlogList posts={beginnerPosts.map(({ data }) => data)} />
      </section>
    )}
    {currentPage > 1 && beginnerPosts.length > 0 && (
      <p class="mb-6 text-sm text-gray-500 dark:text-gray-400">
        <a href="/blog/" class="text-sky-600 hover:underline dark:text-sky-400">← 入門記事</a>は1ページ目にあります
      </p>
    )}
    <BlogList posts={displayData} />
    <Pagination
      currentPage={currentPage}
      lastPage={lastPage}
      prevUrl={prevUrl}
      nextUrl={nextUrl}
    />
  </main>
</Layout>
