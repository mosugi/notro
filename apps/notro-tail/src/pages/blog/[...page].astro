---
import type { CollectionEntry } from "astro:content";
import type { PaginateFunction } from "astro";
import { getCollection } from "astro:content";
import BlogList from "../../components/BlogList.astro";
import Layout from "../../layouts/Layout.astro";
import Pagination from "../../components/Pagination.astro";

export async function getStaticPaths({
  paginate,
}: {
  paginate: PaginateFunction;
}) {
  // Check if an entry has a specific tag value
  function hasTag(entry: CollectionEntry<"posts">, tagName: string): boolean {
    if (entry.data.properties.Tags?.type !== "multi_select") return false;
    return entry.data.properties.Tags.multi_select.some((t) => t.name === tagName);
  }

  const allPosts = await getCollection("posts");

  // Posts tagged "page" are fixed pages, excluded from blog listing
  const blogPosts = allPosts.filter((entry) => !hasTag(entry, "page"));

  // Posts tagged "pinned" are shown at the top of page 1 only
  const pinnedPosts = blogPosts.filter((entry) => hasTag(entry, "pinned"));
  const regularPosts = blogPosts.filter((entry) => !hasTag(entry, "pinned"));

  return paginate(regularPosts, {
    pageSize: 10,
    props: { pinnedPostsData: pinnedPosts.map(({ data }) => data) },
  });
}

const { page, pinnedPostsData } = Astro.props;

const data = page.data.map(({ data }) => data);
---

<Layout title="Blog">
  <main class="mx-auto max-w-screen-xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Blog</h1>
    </div>
    {page.currentPage === 1 && pinnedPostsData.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-4 text-lg font-semibold text-gray-700">ピン留め</h2>
        <BlogList posts={pinnedPostsData} />
      </section>
    )}
    <BlogList posts={data} />
    <Pagination
      currentPage={page.currentPage}
      lastPage={page.lastPage}
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
    />
  </main>
</Layout>
