---
import { getCollection } from "astro:content";
import { getPlainText, NotionMarkdownRenderer } from "notro";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const collection = await getCollection("posts");
  return collection.map((entry) => {
    const slug = getPlainText(entry.data.properties.Slug) || entry.id;
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
---

<Layout title={getPlainText(entry.data.properties.Name) ?? entry.id}>
  <main class="nt-page" id={entry.id}>
    <NotionMarkdownRenderer markdown={entry.data.markdown} />
  </main>
</Layout>
