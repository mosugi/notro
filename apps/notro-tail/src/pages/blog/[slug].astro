---
import { getCollection } from "astro:content";
import {
  NotionMarkdownRenderer,
  getPlainText,
} from "notro";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((entry) => ({
    params: { slug: getPlainText(entry.data.properties.Slug) || entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

const title = getPlainText(entry.data.properties.Name) ?? entry.id;
const description = getPlainText(entry.data.properties.Description);
const date = entry.data.properties.Date.date?.start;
const tags = entry.data.properties.Tags.multi_select;
const markdown = entry.data.markdown;
---

<Layout title={title}>
  <main class="mx-auto max-w-screen-xl px-4 py-8 sm:px-6 lg:px-8">
    <article class="mx-auto max-w-3xl">
      <header class="mb-8 border-b border-gray-100 pb-6">
        <h1 class="mb-3 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">{title}</h1>
        {description && <p class="mb-4 text-lg text-gray-500">{description}</p>}
        <div class="flex flex-wrap items-center gap-3">
          {date && <time datetime={date} class="text-sm text-gray-400">{date}</time>}
          {
            tags.length > 0 && (
              <ul class="flex list-none flex-wrap gap-1.5">
                {tags.map((tag) => (
                  <li>
                    <a
                      href={`/blog/tag/${tag.name}/`}
                      class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs text-gray-600 transition hover:bg-gray-200"
                    >
                      {tag.name}
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </header>

      <div class="nt-article-body">
        <NotionMarkdownRenderer markdown={markdown} />
      </div>
    </article>
  </main>
</Layout>

<style is:global>
  /* Prose typography for Notion markdown content */
  .nt-article-body .nt-markdown-content {
    font-size: 1rem;
    line-height: 1.75;
    color: rgb(31 41 55);
  }

  .nt-article-body .nt-markdown-content h1 {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.875rem;
    font-weight: 700;
    color: rgb(17 24 39);
  }

  .nt-article-body .nt-markdown-content h2 {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-size: 1.5rem;
    font-weight: 600;
    color: rgb(17 24 39);
  }

  .nt-article-body .nt-markdown-content h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: rgb(17 24 39);
  }

  .nt-article-body .nt-markdown-content p {
    margin-bottom: 0.75rem;
    line-height: 1.75rem;
  }

  .nt-article-body .nt-markdown-content ul {
    margin-bottom: 0.75rem;
    list-style-type: disc;
    padding-left: 1.5rem;
  }

  .nt-article-body .nt-markdown-content ol {
    margin-bottom: 0.75rem;
    list-style-type: decimal;
    padding-left: 1.5rem;
  }

  .nt-article-body .nt-markdown-content li {
    margin-bottom: 0.25rem;
    line-height: 1.75rem;
  }

  .nt-article-body .nt-markdown-content blockquote {
    margin: 1rem 0;
    border-left: 4px solid rgb(229 231 235);
    padding-left: 1rem;
    font-style: italic;
    color: rgb(107 114 128);
  }

  .nt-article-body .nt-markdown-content pre {
    margin: 1rem 0;
    overflow-x: auto;
    border-radius: 0.375rem;
    background-color: rgb(249 250 251);
    padding: 1rem;
    font-family: ui-monospace, monospace;
    font-size: 0.875rem;
  }

  .nt-article-body .nt-markdown-content :not(pre) > code {
    border-radius: 0.25rem;
    background-color: rgb(243 244 246);
    padding: 0.125rem 0.25rem;
    font-family: ui-monospace, monospace;
    font-size: 0.875rem;
    color: rgb(31 41 55);
  }

  .nt-article-body .nt-markdown-content hr {
    margin: 2rem 0;
    border-color: rgb(229 231 235);
  }

  .nt-article-body .nt-markdown-content a {
    color: rgb(2 132 199);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .nt-article-body .nt-markdown-content a:hover {
    color: rgb(3 105 161);
  }

  .nt-article-body .nt-markdown-content table {
    margin: 1rem 0;
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .nt-article-body .nt-markdown-content th {
    border: 1px solid rgb(229 231 235);
    background-color: rgb(249 250 251);
    padding: 0.5rem 0.75rem;
    text-align: left;
    font-weight: 600;
    color: rgb(55 65 81);
  }

  .nt-article-body .nt-markdown-content td {
    border: 1px solid rgb(229 231 235);
    padding: 0.5rem 0.75rem;
    color: rgb(55 65 81);
  }

  .nt-article-body .nt-markdown-content img {
    margin: 1rem 0;
    max-width: 100%;
    height: auto;
    border-radius: 0.375rem;
  }

  /* TOC spacing */
  .nt-article-body .nt-toc-level-2 { padding-left: 1rem; }
  .nt-article-body .nt-toc-level-3 { padding-left: 2rem; }
</style>
