---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import { NotionMarkdownRenderer, buildLinkToPages, getPlainText, getMultiSelect, hasTag } from "notro";
import Layout from "../../layouts/Layout.astro";
import { navPages } from "../../config";
import Callout from "../../components/notion/Callout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  // Build linkToPages map so NotionMarkdownRenderer can resolve inter-page links
  const linkToPages = buildLinkToPages(posts, {
    url: (e) => `blog/${getPlainText(e.data.properties.Slug) || e.id}/`,
    title: (e) => getPlainText(e.data.properties.Name) ?? e.id,
  });

  // Build a slug → bodyClass map from navPages config for per-page styling
  const navPageMap = new Map(navPages.map((p) => [p.slug, p]));

  // Sorted blog posts (excluding "page"-tagged fixed pages) for prev/next nav
  const blogPosts = posts
    .filter((entry) => !hasTag(entry.data.properties.Tags, "page"))
    .sort((a, b) => {
      const dateA = a.data.properties.Date.date?.start ?? "";
      const dateB = b.data.properties.Date.date?.start ?? "";
      return dateB.localeCompare(dateA); // newest first
    });

  return posts.map((entry) => {
    const slug = getPlainText(entry.data.properties.Slug) || entry.id;
    const idx = blogPosts.findIndex((p) => p.id === entry.id);

    // In descending date order: idx-1 = newer, idx+1 = older
    const makeNav = (e: CollectionEntry<"posts"> | undefined) =>
      e
        ? {
            slug: getPlainText(e.data.properties.Slug) || e.id,
            title: getPlainText(e.data.properties.Name) ?? e.id,
          }
        : undefined;

    return {
      params: { slug },
      props: {
        entry,
        linkToPages,
        bodyClass: navPageMap.get(slug)?.bodyClass,
        prevNav: makeNav(idx > 0 ? blogPosts[idx - 1] : undefined),         // newer
        nextNav: makeNav(idx >= 0 && idx < blogPosts.length - 1 ? blogPosts[idx + 1] : undefined), // older
      },
    };
  });
}

const { entry, linkToPages, bodyClass, prevNav, nextNav } = Astro.props;

const title = getPlainText(entry.data.properties.Name) ?? entry.id;
const description = getPlainText(entry.data.properties.Description);
const date = entry.data.properties.Date.date?.start;
const tags = getMultiSelect(entry.data.properties.Tags);
const markdown = entry.data.markdown;
---

<style>
  /* Prev/next navigation card hover — CSS :hover replaces JS onmouseover */
  .post-nav-link {
    transition: background 0.15s ease;
  }
  .post-nav-link:hover {
    background: rgba(55, 53, 47, 0.03);
  }
</style>

<Layout title={title} description={description} bodyClass={bodyClass}>
  <main class="mx-auto max-w-screen-xl px-4 py-10 sm:px-6 lg:px-8">
    <article class="mx-auto max-w-[720px]">
      <header class="mb-10 pb-6" style="border-bottom: 1px solid rgba(55,53,47,0.09);">
        <h1 class="mb-3 text-[2rem] font-bold tracking-tight leading-tight" style="color: #37352f;">{title}</h1>
        {description && <p class="mb-4 text-base leading-relaxed" style="color: rgba(55,53,47,0.65);">{description}</p>}
        <div class="flex flex-wrap items-center gap-3">
          {date && <time datetime={date} class="text-sm" style="color: rgba(55,53,47,0.45);">{date}</time>}
          {
            tags.length > 0 && (
              <ul class="flex list-none flex-wrap gap-1.5">
                {tags.map((tag) => (
                  <li>
                    <a
                      href={`/blog/tag/${tag.name}/`}
                      style="font-size: 0.75rem; background: rgba(55,53,47,0.06); color: rgba(55,53,47,0.65); border-radius: 3px; padding: 0.15rem 0.5rem; text-decoration: none; transition: background 0.15s, color 0.15s;"
                    >
                      {tag.name}
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </header>

      <NotionMarkdownRenderer
        markdown={markdown}
        linkToPages={linkToPages}
        classMap={{
          // ── Notion-specific blocks ───────────────────────────
          callout:     "flex items-start gap-3 my-4 rounded-md p-4",
          toggle:      "my-1",
          toggleTitle: "cursor-pointer select-none py-1 font-medium",
          columns:     "grid grid-cols-1 gap-8 my-4 md:grid-cols-2",
          column:      "min-w-0",
          quote:       "my-4 border-l-[3px] pl-4 italic",
          h1:          "mb-3 mt-10 text-[1.875rem] font-bold tracking-tight",
          h2:          "mb-2 mt-8 text-2xl font-semibold tracking-tight",
          h3:          "mb-2 mt-6 text-xl font-semibold",
          h4:          "mb-1 mt-4 text-base font-semibold",
          image:       "my-4",
          tableWrapper:"my-4 w-full overflow-x-auto",
          table:       "w-full border-collapse text-sm",
          tableCell:   "px-3 py-2 text-sm",
          toc:         "my-4 rounded-md p-4 text-sm",
          // ── Standard HTML block elements ─────────────────────
          p:           "mb-4 leading-7",
          ul:          "mb-4 list-disc pl-6 space-y-1",
          ol:          "mb-4 list-decimal pl-6 space-y-1",
          li:          "leading-7",
          pre:         "my-4 overflow-x-auto rounded-md p-4 font-mono text-sm",
          hr:          "my-8",
          // ── Standard HTML inline elements ────────────────────
          a:           "underline underline-offset-2 hover:opacity-70",
          strong:      "font-semibold",
          em:          "italic",
          del:         "line-through",
          // ── Table header cell ─────────────────────────────────
          th:          "px-3 py-2 text-left text-sm font-semibold",
        }}
        components={{ callout: Callout }}
      />

      {entry.data.truncated && (
        <div class="mt-8 rounded-md border border-yellow-300 bg-yellow-50 px-4 py-3 text-sm" style="color: #854d0e;">
          このページのコンテンツは Notion API の制限により一部省略されています。
        </div>
      )}

      {(prevNav || nextNav) && (
        <nav class="mt-12 flex items-stretch gap-4 pt-8 text-sm" style="border-top: 1px solid rgba(55,53,47,0.09);">
          {/* prevNav = newer post (lower index in desc sort) */}
          <div class="flex-1">
            {prevNav && (
              <a
                href={`/blog/${prevNav.slug}/`}
                class="article-nav-link flex h-full flex-col gap-1 rounded-md p-4"
                style="border: 1px solid rgba(55,53,47,0.09); text-decoration: none; color: inherit;"
              >
                <span class="text-xs" style="color: rgba(55,53,47,0.45);">← 新しい記事</span>
                <span class="font-medium line-clamp-2" style="color: #37352f;">{prevNav.title}</span>
              </a>
            )}
          </div>
          {/* nextNav = older post (higher index in desc sort) */}
          <div class="flex-1">
            {nextNav && (
              <a
                href={`/blog/${nextNav.slug}/`}
                class="article-nav-link flex h-full flex-col items-end gap-1 rounded-md p-4 text-right"
                style="border: 1px solid rgba(55,53,47,0.09); text-decoration: none; color: inherit;"
              >
                <span class="text-xs" style="color: rgba(55,53,47,0.45);">古い記事 →</span>
                <span class="font-medium line-clamp-2" style="color: #37352f;">{nextNav.title}</span>
              </a>
            )}
          </div>
        </nav>
      )}
    </article>
  </main>
</Layout>

<style>
  /* Prev/next article nav links — CSS transition instead of inline JS onmouseover */
  .article-nav-link {
    transition: background-color 0.15s ease;
  }
  .article-nav-link:hover {
    background-color: rgba(55, 53, 47, 0.03);
  }
</style>
