---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import { NotionMarkdownRenderer, getPlainText } from "notro";
import Layout from "../../layouts/Layout.astro";
import { navPages } from "../../config";
import Callout from "../../components/notion/Callout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  // Build linkToPages map so NotionMarkdownRenderer can resolve inter-page links
  const linkToPages = Object.fromEntries(
    posts.map((entry) => [
      entry.id,
      {
        url: `blog/${getPlainText(entry.data.properties.Slug) || entry.id}/`,
        title: getPlainText(entry.data.properties.Name) ?? entry.id,
      },
    ]),
  );

  // Build a slug → bodyClass map from navPages config for per-page styling
  const navPageMap = new Map(navPages.map((p) => [p.slug, p]));

  // Sorted blog posts (excluding "page"-tagged fixed pages) for prev/next nav
  const isPageTag = (entry: CollectionEntry<"posts">) =>
    entry.data.properties.Tags?.type === "multi_select" &&
    entry.data.properties.Tags.multi_select.some((t) => t.name === "page");

  const blogPosts = posts
    .filter((entry) => !isPageTag(entry))
    .sort((a, b) => {
      const dateA = a.data.properties.Date.date?.start ?? "";
      const dateB = b.data.properties.Date.date?.start ?? "";
      return dateB.localeCompare(dateA); // newest first
    });

  return posts.map((entry) => {
    const slug = getPlainText(entry.data.properties.Slug) || entry.id;
    const idx = blogPosts.findIndex((p) => p.id === entry.id);

    // In descending date order: idx-1 = newer, idx+1 = older
    const makeNav = (e: CollectionEntry<"posts"> | undefined) =>
      e
        ? {
            slug: getPlainText(e.data.properties.Slug) || e.id,
            title: getPlainText(e.data.properties.Name) ?? e.id,
          }
        : undefined;

    return {
      params: { slug },
      props: {
        entry,
        linkToPages,
        bodyClass: navPageMap.get(slug)?.bodyClass,
        prevNav: makeNav(idx > 0 ? blogPosts[idx - 1] : undefined),         // newer
        nextNav: makeNav(idx >= 0 && idx < blogPosts.length - 1 ? blogPosts[idx + 1] : undefined), // older
      },
    };
  });
}

const { entry, linkToPages, bodyClass, prevNav, nextNav } = Astro.props;

const title = getPlainText(entry.data.properties.Name) ?? entry.id;
const description = getPlainText(entry.data.properties.Description);
const date = entry.data.properties.Date.date?.start;
const tags = entry.data.properties.Tags.multi_select;
const markdown = entry.data.markdown;
---

<Layout title={title} description={description} bodyClass={bodyClass}>
  <main class="mx-auto max-w-screen-xl px-4 py-8 sm:px-6 lg:px-8">
    <article class="mx-auto max-w-3xl">
      <header class="mb-8 border-b border-gray-100 pb-6">
        <h1 class="mb-3 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">{title}</h1>
        {description && <p class="mb-4 text-lg text-gray-500">{description}</p>}
        <div class="flex flex-wrap items-center gap-3">
          {date && <time datetime={date} class="text-sm text-gray-400">{date}</time>}
          {
            tags.length > 0 && (
              <ul class="flex list-none flex-wrap gap-1.5">
                {tags.map((tag) => (
                  <li>
                    <a
                      href={`/blog/tag/${tag.name}/`}
                      class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs text-gray-600 transition hover:bg-gray-200"
                    >
                      {tag.name}
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </header>

      <NotionMarkdownRenderer
        markdown={markdown}
        linkToPages={linkToPages}
        classMap={{
          callout:     "flex items-start gap-3 my-4 rounded-lg border border-gray-200 p-4",
          toggle:      "my-1 rounded-md",
          toggleTitle: "cursor-pointer select-none py-1 font-medium",
          columns:     "grid grid-cols-1 gap-6 my-4 md:grid-cols-2",
          column:      "min-w-0",
          quote:       "my-4 border-l-4 border-gray-200 pl-4 italic text-gray-600",
          h1:          "mb-3 mt-10 text-3xl font-bold text-gray-900",
          h2:          "mb-2 mt-8 text-2xl font-semibold text-gray-900",
          h3:          "mb-2 mt-6 text-xl font-semibold text-gray-900",
          h4:          "mb-1 mt-4 text-lg font-semibold text-gray-900",
          image:       "my-4",
          tableWrapper:"my-4 w-full overflow-x-auto",
          table:       "w-full border-collapse text-sm",
          tableCell:   "border border-gray-200 px-3 py-2 text-gray-700",
          toc:         "my-4 rounded-md bg-gray-50 p-4",
        }}
        components={{ callout: Callout }}
      />

      {(prevNav || nextNav) && (
        <nav class="mt-12 flex items-stretch gap-4 border-t border-gray-100 pt-8 text-sm">
          {/* prevNav = newer post (lower index in desc sort) */}
          <div class="flex-1">
            {prevNav && (
              <a
                href={`/blog/${prevNav.slug}/`}
                class="flex h-full flex-col gap-1 rounded-lg border border-gray-200 p-4 transition hover:border-gray-300 hover:bg-gray-50"
              >
                <span class="text-xs text-gray-400">← 新しい記事</span>
                <span class="font-medium text-gray-800 line-clamp-2">{prevNav.title}</span>
              </a>
            )}
          </div>
          {/* nextNav = older post (higher index in desc sort) */}
          <div class="flex-1">
            {nextNav && (
              <a
                href={`/blog/${nextNav.slug}/`}
                class="flex h-full flex-col items-end gap-1 rounded-lg border border-gray-200 p-4 text-right transition hover:border-gray-300 hover:bg-gray-50"
              >
                <span class="text-xs text-gray-400">古い記事 →</span>
                <span class="font-medium text-gray-800 line-clamp-2">{nextNav.title}</span>
              </a>
            )}
          </div>
        </nav>
      )}
    </article>
  </main>
</Layout>
