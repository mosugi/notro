---
import { getCollection } from "astro:content";
import { NotionMarkdownRenderer, getPlainText } from "notro";
import Layout from "../../layouts/Layout.astro";
import { navPages } from "../../config";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  // Build linkToPages map so NotionMarkdownRenderer can resolve inter-page links
  const linkToPages = Object.fromEntries(
    posts.map((entry) => [
      entry.id,
      {
        url: `blog/${getPlainText(entry.data.properties.Slug) || entry.id}/`,
        title: getPlainText(entry.data.properties.Name) ?? entry.id,
      },
    ]),
  );
  // Build a slug → bodyClass map from navPages config for per-page styling
  const navPageMap = new Map(navPages.map((p) => [p.slug, p]));
  return posts.map((entry) => {
    const slug = getPlainText(entry.data.properties.Slug) || entry.id;
    return {
      params: { slug },
      props: { entry, linkToPages, bodyClass: navPageMap.get(slug)?.bodyClass },
    };
  });
}

const { entry, linkToPages, bodyClass } = Astro.props;

const title = getPlainText(entry.data.properties.Name) ?? entry.id;
const description = getPlainText(entry.data.properties.Description);
const date = entry.data.properties.Date.date?.start;
const tags = entry.data.properties.Tags.multi_select;
const markdown = entry.data.markdown;
---

<Layout title={title} bodyClass={bodyClass}>
  <main class="mx-auto max-w-screen-xl px-4 py-8 sm:px-6 lg:px-8">
    <article class="mx-auto max-w-3xl">
      <header class="mb-8 border-b border-gray-100 pb-6">
        <h1 class="mb-3 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">{title}</h1>
        {description && <p class="mb-4 text-lg text-gray-500">{description}</p>}
        <div class="flex flex-wrap items-center gap-3">
          {date && <time datetime={date} class="text-sm text-gray-400">{date}</time>}
          {
            tags.length > 0 && (
              <ul class="flex list-none flex-wrap gap-1.5">
                {tags.map((tag) => (
                  <li>
                    <a
                      href={`/blog/tag/${tag.name}/`}
                      class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs text-gray-600 transition hover:bg-gray-200"
                    >
                      {tag.name}
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </header>

      <div class="nt-markdown-content">
        <NotionMarkdownRenderer markdown={markdown} linkToPages={linkToPages} />
      </div>
    </article>
  </main>
</Layout>
