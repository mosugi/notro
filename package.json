{
  "name": "root",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosugi/notro.git"
  },
  "scripts": {
    "dev": "pnpm --filter notro-tail run dev",
    "build": "pnpm --filter notro-tail run build",
    "preview": "pnpm --filter notro-tail run preview",
    "docs:dev": "pnpm --filter notro-docs run dev",
    "docs:build": "pnpm --filter notro-docs run build",
    "test": "pnpm -r run test",
    "format": "pnpm -r run format",
    "changeset-version": "changeset version",
    "changeset-publish": "pnpm run build && changeset publish"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1"
  }
}
