{
  "name": "root",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosugi/notro.git"
  },
  "scripts": {
    "dev": "pnpm --filter notro-blog run dev",
    "build": "pnpm --filter notro-blog run build",
    "preview": "pnpm --filter notro-blog run preview",
    "docs:dev": "pnpm --filter notro-docs run dev",
    "docs:build": "pnpm --filter notro-docs run build",
    "test": "pnpm -r run test",
    "format": "pnpm -r run format",
    "build:packages": "pnpm --filter remark-notro --filter rehype-beautiful-mermaid --filter create-notro run build",
    "changeset-version": "changeset version",
    "changeset-publish": "pnpm run build:packages && changeset publish",
    "reflect": "node --experimental-strip-types examples/reflect-to-notion.ts"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"],
    "overrides": {
      "notro-loader": "workspace:*",
      "rehype-beautiful-mermaid": "workspace:*"
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@notionhq/client": "5.11.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1"
  }
}
