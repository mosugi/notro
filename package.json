{
  "name": "root",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosugi/notro.git"
  },
  "scripts": {
    "dev": "npm run dev -w notro-tail",
    "build": "npm run build -w notro-tail",
    "preview": "npm run preview -w notro-tail",
    "docs:dev": "npm run dev -w notro-docs",
    "docs:build": "npm run build -w notro-docs",
    "test": "npm run test --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "changeset-version": "changeset version",
    "changeset-publish": "npm run build && changeset publish"
  },
  "workspaces": [
    "templates/*",
    "packages/*",
    "docs"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1"
  }
}
