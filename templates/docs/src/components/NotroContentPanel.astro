---
import { NotroContent } from "notro-loader";

// entry.data.markdown is provided by notro-loader schema (pageWithMarkdownSchema).
// entry may be undefined for auto-generated pages (404, splash, etc.) that have
// no corresponding docs collection entry.
const { entry } = Astro.props;
const markdown = (entry?.data as { markdown?: string } | undefined)?.markdown;
---

<div class="sl-markdown-content">
  {markdown ? <NotroContent markdown={markdown} /> : <slot />}
</div>
