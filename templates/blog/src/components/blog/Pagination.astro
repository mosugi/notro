---
interface Props {
  currentPage: number;
  lastPage: number;
  prevUrl: string | undefined;
  nextUrl: string | undefined;
}

const { currentPage, lastPage, prevUrl, nextUrl } = Astro.props;
---

{
  lastPage > 1 && (
    <nav class="mt-10 flex items-center justify-center gap-4 text-sm">
      {prevUrl ? (
        <a
          href={prevUrl}
          class="rounded-md border nt-border px-4 py-2 nt-text-60 transition hover:nt-border-18 hover:nt-bg-04"
        >
          ← 前へ
        </a>
      ) : (
        <span class="px-4 py-2 nt-text-30">← 前へ</span>
      )}
      <span class="nt-text-60">
        {currentPage} / {lastPage}
      </span>
      {nextUrl ? (
        <a
          href={nextUrl}
          class="rounded-md border nt-border px-4 py-2 nt-text-60 transition hover:nt-border-18 hover:nt-bg-04"
        >
          次へ →
        </a>
      ) : (
        <span class="px-4 py-2 nt-text-30">次へ →</span>
      )}
    </nav>
  )
}
