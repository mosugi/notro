---
/**
 * Notion audio embed block.
 */
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

export const audio = tv({
  slots: {
    root: 'my-4',
    controls: 'w-full',
    caption: 'text-sm text-[var(--notro-text-muted)] mt-1.5',
  },
});

type Props = HTMLAttributes<'figure'> & {
  src: string;
};

const { src, class: className, ...rest } = Astro.props;
const { root, controls, caption } = audio();
---

<figure class={root({ class: className })} data-slot="audio" {...rest}>
  <audio controls src={src} class={controls()} data-slot="audio-controls"></audio>
  {Astro.slots.has('default') && (
    <figcaption class={caption()} data-slot="audio-caption">
      <slot />
    </figcaption>
  )}
</figure>
