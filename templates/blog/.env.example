# Notion Internal Integration Token
# Get your token at https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Data Source ID for the blog template (recommended).
# Found in your database URL: notion.so/<workspace>/<database_id>?...
# When set, takes precedence over NOTION_DATASOURCE_ID below.
NOTION_DATASOURCE_ID_BLOG=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Fallback Notion Data Source ID.
# Used when NOTION_DATASOURCE_ID_BLOG is not set. Handy if you run
# multiple templates against a single data source.
# NOTION_DATASOURCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Deployment site URL (optional).
# When set, overrides the `site` value in astro.config.mjs. Used for
# generating absolute URLs in sitemap, canonical links, and OG tags.
# SITE_URL=https://example.com
