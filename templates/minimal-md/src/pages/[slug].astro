---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { NotroContent } from "notro-loader";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages.map((page) => ({
    params: { slug: page.data.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
---

<Layout title={page.data.title}>
  <main class="nt-container">
    <article>
      <h1 class="nt-heading">{page.data.title}</h1>
      <div class="notro-markdown">
        <NotroContent markdown={page.data.markdown} />
      </div>
    </article>
  </main>
</Layout>

<style>
  .nt-container {
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
    padding: 3rem 1rem;
  }

  .nt-heading {
    font-size: 1.875rem;
    font-weight: 700;
    margin-bottom: 2rem;
    color: var(--notro-text);
  }
</style>
