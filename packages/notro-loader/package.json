{
  "name": "notro-loader",
  "description": "A Content loader for Astro that uses the Notion Public API",
  "version": "0.0.9",
  "type": "module",
  "author": "mosugi <mosugeek@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosugi/notro.git",
    "directory": "packages/notro-loader"
  },
  "keywords": [
    "astro",
    "withastro",
    "astro-component",
    "astro-integration",
    "astro-loader",
    "notion"
  ],
  "bugs": {
    "url": "https://github.com/mosugi/notro/issues"
  },
  "homepage": "https://github.com/mosugi/notro",
  "exports": {
    ".": {
      "astro": "./index.ts",
      "types": "./index.ts",
      "default": "./integration.ts"
    },
    "./utils": "./utils.ts",
    "./integration": "./integration.ts",
    "./image-service": "./image-service.ts"
  },
  "files": [
    "index.ts",
    "integration.ts",
    "utils.ts",
    "image-service.ts",
    "src"
  ],
  "scripts": {
    "format": "prettier --write 'src/**/*.ts' 'src/**/*.astro'",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "peerDependencies": {
    "astro": ">=6.0.0",
    "unified": ">=11.0.0"
  },
  "devDependencies": {
    "astro": "^6.0.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.0",
    "zod": "^4.0.0",
    "@mdx-js/mdx": "^3.1.0",
    "@notionhq/client": "5.11.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-notro": "workspace:*",
    "unist-util-visit": "^5.0.0"
  },
  "optionalDependencies": {
    "@shikijs/rehype": "^4.0.0"
  }
}
