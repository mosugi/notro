---
import RichText from "./RichText.astro";
import { getNotionColor } from "../utils/notion";
import type { Heading1BlockObjectResponseType } from "../loader/schema.ts";

interface Props {
  block: Heading1BlockObjectResponseType;
  id?: string;
}

const { block, id } = Astro.props;
---

<h2
  id={id}
  class=`nt-selectable nt-header-block ${getNotionColor(block.heading_1.color)}`
>
  <RichText richText={block.heading_1.rich_text} />
  <slot />
</h2>
