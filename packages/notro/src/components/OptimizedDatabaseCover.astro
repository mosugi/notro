---
import { Image } from "astro:assets";
import type { PageObjectResponseType } from "../loader/schema.ts";
interface Props {
  cover: PageObjectResponseType["cover"];
  alt?: string;
}

const { cover, alt } = Astro.props;

const imageUrl = cover?.type === "file" ? cover?.file.url : cover?.external?.url;
---

{
  imageUrl ? (
    <div class="nt-collection-cover">
      <Image
        src={imageUrl}
        alt={alt ?? ""}
        width={1200}
        height={630}
      />
    </div>
  ) : null
}
