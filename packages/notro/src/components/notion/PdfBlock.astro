---
/** <pdf src="URL" color="Color">Caption</pdf> */
import { colorToCSS } from './colors';

interface Props { src: string; color?: string; class?: string; }
const { src, color, class: className } = Astro.props;
---
<figure class:list={["notion-pdf", className]} style={colorToCSS(color)}>
	<iframe src={src} class="notion-pdf__frame" title="PDF" loading="lazy"></iframe>
	{Astro.slots.has('default') && <figcaption class="notion-pdf__caption"><slot /></figcaption>}
</figure>