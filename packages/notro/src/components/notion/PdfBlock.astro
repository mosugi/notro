---
/**
 * Notion PDF embed block.
 */
import { tv } from 'tailwind-variants';

export const pdfBlock = tv({ base: 'my-4' });

interface Props { src: string; class?: string; }
const { src, class: className } = Astro.props;
---

<figure class={pdfBlock({ class: className })}>
  <iframe src={src} class="w-full min-h-[500px] border-0" title="PDF" loading="lazy"></iframe>
  {Astro.slots.has('default') && (
    <figcaption class="text-sm text-[var(--notro-text-muted)] mt-1.5">
      <slot />
    </figcaption>
  )}
</figure>
