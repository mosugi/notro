---
/** <pdf src="URL" color="Color">Caption</pdf> */
interface Props { src: string; color?: string; }
const { src } = Astro.props;
---
<figure class="notion-pdf">
	<iframe src={src} class="notion-pdf__frame" title="PDF" loading="lazy"></iframe>
	{Astro.slots.has('default') && <figcaption class="notion-pdf__caption"><slot /></figcaption>}
</figure>
<style>
	.notion-pdf { margin: 0.75rem 0; }
	.notion-pdf__frame { width: 100%; height: 600px; border: 1px solid #e5e7eb; border-radius: 0.375rem; }
	.notion-pdf__caption { font-size: 0.875rem; color: #6b7280; margin-top: 0.375rem; text-align: center; }
</style>
