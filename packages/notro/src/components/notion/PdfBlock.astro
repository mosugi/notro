---
/** <pdf src="URL" color="Color">Caption</pdf> */
import type { NotionColor } from "./colors.ts";
interface Props { src: string; color?: NotionColor; class?: string; }
const { src, color, class: className } = Astro.props;
---
<figure data-pdf-block data-color={color || undefined} class:list={[className]}>
	<iframe src={src} data-pdf-frame title="PDF" loading="lazy"></iframe>
	{Astro.slots.has('default') && <figcaption data-pdf-caption><slot /></figcaption>}
</figure>
