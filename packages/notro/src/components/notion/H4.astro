---
import { colorToCSS } from './colors';
import { getClass } from '../../utils/classRegistry';
interface Props { color?: string; id?: string; class?: string; }
const { color, id, class: className } = Astro.props;
---
<h4 {id} class:list={["notion-h4", getClass('h4'), className]} style={colorToCSS(color)}><slot /></h4>