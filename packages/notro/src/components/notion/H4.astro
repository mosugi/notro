---
import { colorToCSS } from './colors';
interface Props { color?: string; id?: string; }
const { color, id } = Astro.props;
---
<h4 {id} class="notion-h4" style={colorToCSS(color)}><slot /></h4>
<style>
	.notion-h4 { font-size: 1.125rem; font-weight: 600; margin: 0.875rem 0 0.25rem; line-height: 1.4; }
</style>
