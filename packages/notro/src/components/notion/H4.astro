---
import { tv, type VariantProps } from 'tailwind-variants';
import { notroColorVariants } from './colors';

export const h4 = tv({
  base: 'mb-1 mt-4 text-base font-semibold',
  variants: { color: notroColorVariants },
});

interface Props extends VariantProps<typeof h4> {
  id?: string;
  class?: string;
}

const { color, id, class: className } = Astro.props;
---
<h4 {id} class={h4({ color, class: className })}><slot /></h4>
