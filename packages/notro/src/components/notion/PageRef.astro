---
/**
 * <page url="URL" color="Color">Title</page>
 *
 * Link to a Notion page.
 */
import { colorToCSS } from './colors';
interface Props { url: string; color?: string; }
const { url, color } = Astro.props;
---
<a href={url} class="notion-page-ref" style={colorToCSS(color)}>
	<span class="notion-page-ref__icon" aria-hidden="true">📄</span>
	<slot />
</a>
<style>
	.notion-page-ref {
		display: flex; align-items: center; gap: 0.5rem;
		padding: 0.375rem 0.5rem; border-radius: 0.25rem;
		color: inherit; text-decoration: none; font-size: 0.9375rem;
		margin: 0.25rem 0;
	}
	.notion-page-ref:hover { background-color: #f3f4f6; }
</style>
