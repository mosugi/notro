---
/**
 * <page url="URL" color="Color">Title</page>
 *
 * Link to a Notion page.
 */
import { colorToCSS } from './colors';
import { getClass } from '../../utils/classRegistry';
interface Props { url: string; color?: string; class?: string; }
const { url, color, class: className } = Astro.props;
---
<a href={url} class:list={["notion-page-ref", getClass('pageRef'), className]} style={colorToCSS(color)}>
	<span class="notion-page-ref__icon" aria-hidden="true">📄</span>
	<slot />
</a>