---
/**
 * <database url="URL" inline="true|false" icon="Emoji" color="Color">Title</database>
 *
 * Link to a Notion database.
 */
import { colorToCSS } from './colors';
interface Props { url: string; inline?: string; icon?: string; color?: string; }
const { url, inline = 'false', icon = '🗄️', color } = Astro.props;
---
<a
	href={url}
	class:list={['notion-database-ref', { 'notion-database-ref--inline': inline === 'true' }]}
	style={colorToCSS(color)}
>
	<span class="notion-database-ref__icon" aria-hidden="true">{icon}</span>
	<slot />
</a>
<style>
	.notion-database-ref {
		display: flex; align-items: center; gap: 0.5rem;
		padding: 0.375rem 0.5rem; border-radius: 0.25rem;
		color: inherit; text-decoration: none; font-size: 0.9375rem;
		margin: 0.25rem 0;
	}
	.notion-database-ref--inline { display: inline-flex; margin: 0 0.125rem; }
	.notion-database-ref:hover { background-color: #f3f4f6; }
</style>
