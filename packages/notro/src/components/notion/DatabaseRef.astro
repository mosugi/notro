---
/**
 * <database url="URL" inline="true|false" icon="Emoji" color="Color">Title</database>
 *
 * Link to a Notion database.
 */
import { colorToClass } from './colors';
interface Props { url: string; inline?: string; icon?: string; color?: string; class?: string; }
const { url, inline = 'false', icon = '🗄️', color, class: className } = Astro.props;
---
<a
	href={url}
	class:list={['nt-database-ref', colorToClass(color), className, { 'nt-database-ref--inline': inline === 'true' }]}
>
	<span class="nt-database-ref__icon" aria-hidden="true">{icon}</span>
	<slot />
</a>