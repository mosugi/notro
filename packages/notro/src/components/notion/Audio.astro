---
/** <audio src="URL" color="Color">Caption</audio> */
import { colorToCSS } from './colors';

interface Props { src: string; color?: string; class?: string; }
const { src, color, class: className } = Astro.props;
---
<figure class:list={["notion-media notion-media--audio", className]} style={colorToCSS(color)}>
	<audio controls src={src} class="notion-media__player"></audio>
	{Astro.slots.has('default') && <figcaption class="notion-media__caption"><slot /></figcaption>}
</figure>