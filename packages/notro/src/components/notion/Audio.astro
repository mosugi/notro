---
/** <audio src="URL" color="Color">Caption</audio> */
import { colorToClass } from './colors';

interface Props { src: string; color?: string; class?: string; }
const { src, color, class: className } = Astro.props;
---
<figure class:list={[colorToClass(color), className]} data-media-type="audio">
	<audio controls src={src} data-media-player></audio>
	{Astro.slots.has('default') && <figcaption data-media-caption><slot /></figcaption>}
</figure>