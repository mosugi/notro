---
/** <file src="URL" color="Color">Caption</file> */
interface Props { src: string; color?: string; }
const { src } = Astro.props;
---
<div class="notion-file">
	<a href={src} target="_blank" rel="noopener noreferrer" class="notion-file__link">
		<span class="notion-file__icon">📎</span>
		<slot />
	</a>
</div>
<style>
	.notion-file { margin: 0.75rem 0; }
	.notion-file__link {
		display: inline-flex; align-items: center; gap: 0.5rem;
		padding: 0.5rem 0.75rem; border-radius: 0.375rem;
		border: 1px solid #e5e7eb; color: inherit; text-decoration: none;
		font-size: 0.9375rem;
	}
	.notion-file__link:hover { background-color: #f9fafb; }
</style>
