---
/** <file src="URL" color="Color">Caption</file> */
import { colorToClass } from './colors';

interface Props { src: string; color?: string; class?: string; }
const { src, color, class: className } = Astro.props;
---
<div class:list={["nt-file-block", colorToClass(color), className]}>
	<a href={src} target="_blank" rel="noopener noreferrer" class="nt-file-block__link">
		<span class="nt-file-block__icon">📎</span>
		<slot />
	</a>
</div>