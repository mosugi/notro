---
/**
 * <mention-date start="YYYY-MM-DD" end="YYYY-MM-DD"/>
 * <mention-date start="YYYY-MM-DD" startTime="HH:mm" timeZone="IANA_TIMEZONE"/>
 *
 * Mapped to MDX `components['mention-date']`.
 */
interface Props {
	start: string;
	end?: string;
	startTime?: string;
	timeZone?: string;
}

const { start, end, startTime, timeZone } = Astro.props;

const parts: string[] = [start];
if (startTime) parts.push(startTime);
if (end) parts.push(`→ ${end}`);
if (timeZone) parts.push(`(${timeZone})`);
const display = parts.join(' ');
---

<time class="notion-date" datetime={start}>{display}</time>

<style>
	.notion-date {
		display: inline;
		padding: 0 0.2em;
		border-radius: 0.25em;
		background-color: #f3f4f6;
		color: #374151;
		font-size: 0.9em;
	}
</style>
