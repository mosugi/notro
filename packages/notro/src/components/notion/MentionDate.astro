---
/**
 * Inline date mention.
 */
import { tv } from 'tailwind-variants';

export const mentionDate = tv({ base: 'font-mono text-sm' });

interface Props {
  start: string;
  end?: string;
  startTime?: string;
  timeZone?: string;
  class?: string;
}

const { start, end, startTime, timeZone, class: className } = Astro.props;

const parts: string[] = [start];
if (startTime) parts.push(startTime);
if (end) parts.push(`→ ${end}`);
if (timeZone) parts.push(`(${timeZone})`);
const display = parts.join(' ');
---

<time class={mentionDate({ class: className })} datetime={start}>{display}</time>
