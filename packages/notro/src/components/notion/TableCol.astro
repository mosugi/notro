---
/**
 * <col color="Color">
 *
 * Applies background color to a column.
 * Color priority: cell > row > column.
 * Mapped to MDX `components.col`.
 */
import type { NotionColor } from "./colors.ts";
interface Props { color?: NotionColor; class?: string; }
const { color, class: className } = Astro.props;
---
<col data-color={color || undefined} class:list={[className]} />
