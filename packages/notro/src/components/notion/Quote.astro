---
/**
 * > Rich text {color="Color"}
 *   Children
 *
 * Mapped to MDX `components.blockquote`.
 */
import type { NotionColor } from "./colors.ts";

interface Props {
	color?: NotionColor;
	class?: string;
}

const { color, class: className } = Astro.props;
---

<blockquote data-color={color || undefined} class:list={[className]}>
	<slot />
</blockquote>
