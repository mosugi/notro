---
/**
 * > Rich text {color="Color"}
 *   Children
 *
 * Mapped to MDX `components.blockquote`.
 */
import { colorToCSS } from './colors';
import { getClass } from '../../utils/classRegistry';

interface Props {
	color?: string;
	class?: string;
}

const { color, class: className } = Astro.props;
---

<blockquote class:list={["notion-quote", getClass('quote'), className]} style={colorToCSS(color)}>
	<slot />
</blockquote>
