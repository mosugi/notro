---
/**
 * > Rich text {color="Color"}
 *   Children
 *
 * Mapped to MDX `components.blockquote`.
 */
import { colorToClass } from './colors';

interface Props {
	color?: string;
	class?: string;
}

const { color, class: className } = Astro.props;
---

<blockquote class:list={["nt-quote-block", colorToClass(color), className]}>
	<slot />
</blockquote>
