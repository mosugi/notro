---
import { colorToCSS } from './colors';
interface Props { color?: string; }
const { color } = Astro.props;
---
<td class="notion-td" style={colorToCSS(color)}><slot /></td>
<style>
	.notion-td {
		padding: 0.5rem 0.75rem;
		border: 1px solid #e5e7eb;
		vertical-align: top;
		min-width: 6rem;
	}
</style>
