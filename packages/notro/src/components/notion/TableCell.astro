---
// Thin wrapper around TableCellBase.astro for the td element.
import TableCellBase from './TableCellBase.astro';
interface Props { color?: string; class?: string; }
const { color, class: className } = Astro.props;
---
<TableCellBase tag="td" baseClass="nt-table-cell" {color} class={className}><slot /></TableCellBase>
