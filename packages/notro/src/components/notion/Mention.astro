---
/**
 * <mention-user url="URL">User name</mention-user>
 * <mention-page url="URL">Page title</mention-page>
 * <mention-database url="URL">Database name</mention-database>
 * <mention-data-source url="URL">Data source name</mention-data-source>
 * <mention-agent url="URL">Agent name</mention-agent>
 *
 * Mapped to MDX `components['mention-user']` etc.
 * All mention types render as inline links.
 */
interface Props {
	url: string;
}

const { url } = Astro.props;
---

<a href={url} class="notion-mention">@<slot /></a>

<style>
	.notion-mention {
		display: inline;
		padding: 0 0.2em;
		border-radius: 0.25em;
		background-color: #eff6ff;
		color: #1d4ed8;
		font-size: 0.9em;
		text-decoration: none;
		font-weight: 500;
	}
	.notion-mention:hover {
		background-color: #dbeafe;
	}
</style>
