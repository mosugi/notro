---
/**
 * <span color="Color">text</span>
 * <span underline="true">text</span>
 *
 * Mapped to MDX `components.span`.
 * Supports inline text color, underline, and an optional extra class
 * (e.g. injected via classMap.span).
 */
import { colorToCSS } from './colors';

interface Props {
	color?: string;
	underline?: string;
	class?: string;
}

const { color, underline, class: className } = Astro.props;
const style = [colorToCSS(color), underline === 'true' ? 'text-decoration:underline' : '']
	.filter(Boolean)
	.join(';');
---

<span class:list={[className]} style={style || undefined}><slot /></span>
