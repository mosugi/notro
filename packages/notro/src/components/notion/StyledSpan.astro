---
/**
 * <span color="Color">text</span>
 * <span underline="true">text</span>
 *
 * Mapped to MDX `components.span`.
 * Supports inline text color, underline, and an optional extra class
 * (e.g. injected via classMap.span).
 */
import { colorToClass } from './colors';

interface Props {
	color?: string;
	underline?: string;
	class?: string;
}

const { color, underline, class: className } = Astro.props;
// Underline cannot be expressed as a reusable CSS class here, so it remains inline.
const style = underline === 'true' ? 'text-decoration:underline' : undefined;
---

<span class:list={[colorToClass(color), className]} style={style}><slot /></span>
