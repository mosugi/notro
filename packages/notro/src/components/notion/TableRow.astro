---
// Thin wrapper around TableCellBase.astro for the tr element.
import TableCellBase from './TableCellBase.astro';
interface Props { color?: string; class?: string; }
const { color, class: className } = Astro.props;
---
<TableCellBase tag="tr" baseClass="nt-table-row" {color} class={className}><slot /></TableCellBase>
