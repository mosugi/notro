---
/**
 * <table fit-page-width="true|false" header-row="true|false" header-column="true|false">
 *   ...
 * </table>
 *
 * Mapped to MDX `components.table`.
 * Color priority (high → low): cell > row > column
 */
interface Props {
	'fit-page-width'?: string;
	'header-row'?: string;
	'header-column'?: string;
	class?: string;
	tableWrapperClass?: string;
}

const {
	'fit-page-width': fitPageWidth = 'false',
	'header-row': headerRow = 'false',
	'header-column': headerColumn = 'false',
	class: className,
	tableWrapperClass,
} = Astro.props;
---

<div class:list={[tableWrapperClass, fitPageWidth === 'true' && 'w-full']}>
	<table
		class:list={[className, 'border nt-border']}
		data-header-row={headerRow === 'true' ? '' : undefined}
		data-header-col={headerColumn === 'true' ? '' : undefined}
	>
		<slot />
	</table>
</div>
