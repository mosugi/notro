---
/**
 * <table fit-page-width="true|false" header-row="true|false" header-column="true|false">
 *   ...
 * </table>
 *
 * Mapped to MDX `components.table`.
 * Color priority (high → low): cell > row > column
 */
interface Props {
	'fit-page-width'?: string;
	'header-row'?: string;
	'header-column'?: string;
	class?: string;
	tableWrapperClass?: string;
}

const {
	'fit-page-width': fitPageWidth = 'false',
	'header-row': headerRow = 'false',
	'header-column': headerColumn = 'false',
	class: className,
	tableWrapperClass,
} = Astro.props;
---

<div
	class:list={[
		'notion-table-wrapper',
		tableWrapperClass,
		{ 'notion-table-wrapper--full': fitPageWidth === 'true' },
	]}
>
	<table
		class:list={[
			'notion-table',
			className,
			{ 'notion-table--header-row': headerRow === 'true' },
			{ 'notion-table--header-col': headerColumn === 'true' },
		]}
	>
		<slot />
	</table>
</div>
