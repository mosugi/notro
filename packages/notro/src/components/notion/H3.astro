---
import { colorToCSS } from './colors';
interface Props { color?: string; id?: string; }
const { color, id } = Astro.props;
---
<h3 {id} class="notion-h3" style={colorToCSS(color)}><slot /></h3>
<style>
	.notion-h3 { font-size: 1.25rem; font-weight: 600; margin: 1rem 0 0.375rem; line-height: 1.4; }
</style>
