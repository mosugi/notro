---
/**
 * <callout icon="🎯" color="blue_bg">
 *   Content here
 * </callout>
 */
import { colorToClass } from './colors';

interface Props {
	icon?: string;
	color?: string;
	class?: string;
}

const { icon, color, class: className } = Astro.props;
---

<div role="note" class:list={[colorToClass(color) || 'nt-color-gray_background', className]}>
	{icon && <span data-callout-icon aria-hidden="true">{icon}</span>}
	<div data-callout-body>
		<slot />
	</div>
</div>
