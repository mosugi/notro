---
/**
 * <callout icon="🎯" color="blue_bg">
 *   Content here
 * </callout>
 */
import { colorToClass } from './colors';

interface Props {
	icon?: string;
	color?: string;
	class?: string;
}

const { icon, color, class: className } = Astro.props;
---

<div class:list={[colorToClass(color) || 'nt-color-gray_background', className]}>
	{icon && <span class="shrink-0 text-xl leading-none" data-callout-icon aria-hidden="true">{icon}</span>}
	<div class="min-w-0 flex-1 [&>:first-child]:mt-0 [&>:last-child]:mb-0" data-callout-body>
		<slot />
	</div>
</div>
