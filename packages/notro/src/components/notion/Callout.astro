---
/**
 * <callout icon="🎯" color="blue_background">
 *   Content here
 * </callout>
 */
interface Props {
	icon?: string;
	color?: string;
	class?: string;
}

const { icon, color, class: className } = Astro.props;
---

<div data-callout data-color={color || 'gray_background'} class:list={[className]}>
	{icon && <span data-callout-icon aria-hidden="true">{icon}</span>}
	<div data-callout-body>
		<slot />
	</div>
</div>
