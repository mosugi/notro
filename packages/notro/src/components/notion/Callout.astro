---
/**
 * <callout icon="🎯" color="blue_bg">
 *   Content here
 * </callout>
 */
import { colorToClass } from './colors';

interface Props {
	icon?: string;
	color?: string;
	class?: string;
}

const { icon, color, class: className } = Astro.props;
---

<div class:list={["nt-callout-block", colorToClass(color) || 'nt-color-gray_background', className]}>
	{icon && <span class="nt-callout-block__icon" aria-hidden="true">{icon}</span>}
	<div class="nt-callout-block__body">
		<slot />
	</div>
</div>
