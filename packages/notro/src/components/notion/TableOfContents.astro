---
/**
 * <table_of_contents color="Color"/>
 *
 * Table of contents block. Populated at compile time by rehypeTocPlugin.
 */
import type { NotionColor } from "./colors.ts";
interface Props { color?: NotionColor; class?: string; }
const { color, class: className } = Astro.props;
---

<nav data-toc data-color={color || undefined} class:list={[className]} aria-label="目次">
	<p data-toc-label>📋 目次</p>
	<slot />
</nav>
