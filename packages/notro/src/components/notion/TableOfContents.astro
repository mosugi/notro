---
/**
 * <table_of_contents color="Color"/>
 *
 * Table of contents block. Populated at compile time by rehypeTocPlugin
 * (mdx-pipeline.ts), which injects <ul class="nt-toc-block__list"> children
 * containing anchor links to every h1–h4 in the document (IDs added by
 * rehype-slug). The <slot /> renders those children inside the <nav>.
 */
import { colorToClass } from './colors';
interface Props { color?: string; class?: string; }
const { color, class: className } = Astro.props;
---

<nav class:list={[colorToClass(color), className]} aria-label="目次">
	<p data-toc-label>📋 目次</p>
	<slot />
</nav>
