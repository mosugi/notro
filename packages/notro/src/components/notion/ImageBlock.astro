---
/**
 * ![Caption](URL) {color="Color"}
 *
 * Notion image block. Mapped to MDX `components.img`.
 *
 * - `alt` is always set on the <img> element for screen readers.
 * - `caption` is a separate prop for visible caption text rendered in <figcaption>.
 *   If `caption` is not provided, no <figcaption> is rendered.
 */
import { colorToClass } from './colors';

interface Props { src: string; alt?: string; caption?: string; color?: string; class?: string; }
const { src, alt, caption, color, class: className } = Astro.props;
---
<figure class:list={[colorToClass(color), className]}>
	<img src={src} alt={alt ?? ''} loading="lazy" decoding="async" class="h-auto max-w-full" data-image-img />
	{caption && <figcaption class="text-sm text-gray-500 mt-1.5 text-center dark:text-slate-400" data-image-caption>{caption}</figcaption>}
</figure>