---
/**
 * ![Caption](URL) {color="Color"}
 *
 * Notion image block. Mapped to MDX `components.img`.
 */
import { getClass } from '../../utils/classRegistry';
interface Props { src: string; alt?: string; color?: string; class?: string; }
const { src, alt, class: className } = Astro.props;
---
<figure class:list={["notion-image", getClass('image'), className]}>
	<img src={src} alt={alt ?? ''} loading="lazy" class="notion-image__img" />
	{alt && <figcaption class="notion-image__caption">{alt}</figcaption>}
</figure>