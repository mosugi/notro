---
/**
 * <summary>Toggle title</summary>
 *
 * Mapped to MDX `components.summary`.
 * Placed directly inside Toggle.astro (<details>).
 */
import { getClass } from '../../utils/classRegistry';

interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<summary class:list={["notion-toggle__title", getClass('toggleTitle'), className]}>
	<slot />
</summary>
