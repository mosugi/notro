---
/**
 * <summary>Toggle title</summary>
 *
 * Mapped to MDX `components.summary`.
 * Placed directly inside Toggle.astro (<details>).
 */
interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<summary class:list={["nt-toggle-block__title", className]}>
	<slot />
</summary>
