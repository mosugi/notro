---
/** <video src="URL" color="Color">Caption</video> */
interface Props { src: string; color?: string; }
const { src } = Astro.props;
---
<figure class="notion-media notion-media--video">
	<video controls src={src} class="notion-media__player"></video>
	{Astro.slots.has('default') && <figcaption class="notion-media__caption"><slot /></figcaption>}
</figure>
<style>
	.notion-media { margin: 0.75rem 0; }
	.notion-media--video .notion-media__player { width: 100%; border-radius: 0.375rem; }
	.notion-media__caption { font-size: 0.875rem; color: #6b7280; margin-top: 0.375rem; text-align: center; }
</style>
