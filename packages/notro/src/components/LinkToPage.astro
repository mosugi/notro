---
import type { LinkToPageBlockObjectResponse } from "@notionhq/client/build/src/api-endpoints";
interface Props {
  block: LinkToPageBlockObjectResponse;
  href?: string;
  text?: string;
}

const { block, href, text } = Astro.props;
---

<a
  id={block.id}
  class=`notion-selectable notion-alias-block`
  href={href ?? block.id}
>
  {text ?? block.id}
</a>
