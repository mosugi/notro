---
import RichText from "./RichText.astro";
import type { NumberedListItemBlockObjectResponseType } from "../loader/schema.ts";

interface Props {
  block: NumberedListItemBlockObjectResponseType;
  id?: string;
}

const { block, id } = Astro.props;
---

<li
  {id}
  class=`nt-selectable nt-numbered_list-block nt-color-${block.numbered_list_item.color}`
>
  <RichText richText={block.numbered_list_item.rich_text} />
  <slot />
</li>
