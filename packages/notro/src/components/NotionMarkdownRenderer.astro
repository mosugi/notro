---
/**
 * Headless Notion markdown renderer.
 *
 * Compiles preprocessed Notion markdown via compileMdxCached() and renders it
 * with the default (unstyled) notionComponents mapping.
 *
 * For a fully-styled renderer, install notro-ui:
 *   npx notro-ui init
 * Then import the local renderer from src/components/notro/NotionMarkdownRenderer.astro.
 */
import { compileMdxCached } from '../utils/compile-mdx.ts';
import { notionComponents } from './notion/index.ts';
import type { LinkToPages } from '../types.ts';

interface Props {
  markdown: string;
  linkToPages?: LinkToPages;
  class?: string;
}

const { markdown, linkToPages, class: className } = Astro.props;

const Content = await compileMdxCached(markdown, { linkToPages });
---

<div class:list={[className]}>
  <Content components={notionComponents} />
</div>
