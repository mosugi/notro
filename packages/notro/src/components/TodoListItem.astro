---
import RichText from "./RichText.astro";
import type { ToDoBlockObjectResponseType } from "../loader/schema.ts";
interface Props {
  block: ToDoBlockObjectResponseType;
  id?: string;
}

const { block, id } = Astro.props;
const inputId = `${id ?? block.id}-todo-input`;
---

<li {id} class=`nt-selectable nt-to_do-block`>
  <input id={inputId} type="checkbox" checked={block.to_do.checked} disabled />
  <label for={inputId}>
    {
      block.to_do.checked ? (
        <s>
          <RichText richText={block.to_do.rich_text} />
        </s>
      ) : (
        <RichText richText={block.to_do.rich_text} />
      )
    }
  </label>
  <slot />
</li>
