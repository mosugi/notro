---
import RichText from "./RichText.astro";
import type { ParagraphBlockObjectResponseType } from "../loader/schema.ts";

interface Props {
  block: ParagraphBlockObjectResponseType;
  id?: string;
}

const { block, id } = Astro.props;
---

<p {id} class=`nt-selectable nt-text-block nt-color-${block.paragraph.color}`>
  <RichText richText={block.paragraph.rich_text} />
  <slot />
</p>
