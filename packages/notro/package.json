{
  "name": "notro",
  "description": "A Content loader for Astro that uses the Notion Public API",
  "version": "0.0.1",
  "type": "module",
  "author": "mosugi <mosugeek@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosugi/NotroTail.git",
    "directory": "packages/notro"
  },
  "keywords": [
    "astro",
    "withastro",
    "astro-component",
    "astro-loader",
    "notion"
  ],
  "bugs": {
    "url": "https://github.com/mosugi/NotroTail/issues"
  },
  "homepage": "https://notrotail.mosugi.com",
  "exports": {
    ".": "./index.ts",
    "./utils": "./utils.ts",
    "./integration": "./integration.ts"
  },
  "files": [
    "index.ts",
    "integration.ts",
    "utils.ts",
    "src/components",
    "src/loader",
    "src/utils"
  ],
  "scripts": {
    "format": "prettier --write 'src/**/*.ts' 'src/**/*.astro'",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "peerDependencies": {
    "astro": ">=6.0.0",
    "unified": ">=11.0.0"
  },
  "devDependencies": {
    "astro": "^6.0.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "provenance": true
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.0",
    "@mdx-js/mdx": "^3.1.0",
    "@notionhq/client": "5.11.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-nfm": "*",
    "unist-util-visit": "^5.0.0"
  },
  "optionalDependencies": {
    "@shikijs/rehype": "^4.0.0"
  }
}
