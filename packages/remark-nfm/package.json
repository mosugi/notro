{
  "name": "remark-notro",
  "description": "Remark plugin for Notion-flavored Markdown (NFM)",
  "version": "0.0.2",
  "type": "module",
  "author": "mosugi <mosugeek@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosugi/NotroTail.git",
    "directory": "packages/remark-notro"
  },
  "keywords": [
    "remark",
    "remark-plugin",
    "notion",
    "markdown",
    "unified"
  ],
  "bugs": {
    "url": "https://github.com/mosugi/NotroTail/issues"
  },
  "homepage": "https://notrotail.mosugi.com",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "tsdown",
    "build": "tsdown",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "mdast-util-directive": "^3.0.0",
    "mdast-util-gfm-strikethrough": "^2.0.0",
    "mdast-util-gfm-task-list-item": "^2.0.0",
    "micromark-extension-directive": "^4.0.0",
    "micromark-extension-gfm-strikethrough": "^2.0.0",
    "micromark-extension-gfm-task-list-item": "^2.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "unified": ">=11.0.0"
  },
  "devDependencies": {
    "tsdown": "^0.12.9",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
