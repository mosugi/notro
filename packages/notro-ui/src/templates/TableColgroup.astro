---
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

export const tableColgroup = tv({ base: '' });

interface Props extends HTMLAttributes<'colgroup'> {}

const { class: className, ...rest } = Astro.props;
---
<colgroup class={tableColgroup({ class: className })} {...rest}><slot /></colgroup>
