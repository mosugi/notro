---
/**
 * Toggle block title — renders as <summary> inside Toggle (<details>).
 * Cursor and marker styles are set by `.notro-toggle > summary` in notro-theme.css.
 */
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

export const toggleTitle = tv({ base: 'font-medium py-0.5' });

interface Props extends HTMLAttributes<'summary'> {}

const { class: className, ...rest } = Astro.props;
---

<summary class={toggleTitle({ class: className })} {...rest}>
  <slot />
</summary>
