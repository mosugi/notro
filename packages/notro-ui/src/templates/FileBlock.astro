---
/**
 * Notion file attachment block.
 */
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

export const fileBlock = tv({ base: 'my-2' });

interface Props extends HTMLAttributes<'div'> {
  src: string;
}

const { src, class: className, ...rest } = Astro.props;
---

<div class={fileBlock({ class: className })} {...rest}>
  <a
    href={src}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1.5 text-[var(--notro-text)] underline underline-offset-2 hover:opacity-70"
  >
    <span class="text-base" aria-hidden="true">📎</span>
    <slot />
  </a>
</div>
