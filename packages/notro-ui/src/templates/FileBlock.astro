---
/**
 * Notion file attachment block.
 */
import { tv } from 'tailwind-variants';

export const fileBlock = tv({ base: 'my-2' });

interface Props { src: string; class?: string; }
const { src, class: className } = Astro.props;
---

<div class={fileBlock({ class: className })}>
  <a
    href={src}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1.5 text-[var(--notro-text)] underline underline-offset-2 hover:opacity-70"
  >
    <span class="text-base" aria-hidden="true">📎</span>
    <slot />
  </a>
</div>
