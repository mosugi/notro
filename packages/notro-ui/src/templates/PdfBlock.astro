---
/**
 * Notion PDF embed block.
 */
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

export const pdfBlock = tv({
  slots: {
    root: 'my-4',
    embed: 'w-full min-h-[500px] border-0',
    caption: 'text-sm text-[var(--notro-text-muted)] mt-1.5',
  },
});

interface Props extends HTMLAttributes<'figure'> {
  src: string;
}

const { src, class: className, ...rest } = Astro.props;
const { root, embed, caption } = pdfBlock();
---

<figure class={root({ class: className })} {...rest}>
  <iframe src={src} class={embed()} title="PDF" loading="lazy"></iframe>
  {Astro.slots.has('default') && (
    <figcaption class={caption()}>
      <slot />
    </figcaption>
  )}
</figure>
