---
/**
 * Notion table of contents block.
 * List items are injected by rehypeTocPlugin with `.notro-toc-item` and `.notro-toc-level-*`.
 * List and item styles are defined in notro-theme.css.
 */
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import { notroColorVariants } from './colors';

export const tableOfContents = tv({
  base: 'my-4 rounded-lg border border-[var(--notro-border)] bg-[var(--notro-bg-subtle)] p-4 text-sm',
  variants: { color: notroColorVariants },
});

interface Props extends Omit<HTMLAttributes<'nav'>, 'color'>, VariantProps<typeof tableOfContents> {}

const { color, class: className, ...rest } = Astro.props;
---

<nav class={tableOfContents({ color, class: className })} aria-label="目次" {...rest}>
  <p class="font-semibold text-sm text-[var(--notro-text-muted)] mb-2">📋 目次</p>
  <slot />
</nav>
