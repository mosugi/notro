---
/**
 * Synced block — passes children through as-is.
 */
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

export const syncedBlock = tv({ base: '' });

interface Props extends HTMLAttributes<'div'> {
  url?: string;
}

const { url, class: className, ...rest } = Astro.props;
const hasSource = url != null && url.length > 0;
---

<div class={syncedBlock({ class: className })} data-has-source={hasSource || undefined} {...rest}>
  <slot />
</div>
