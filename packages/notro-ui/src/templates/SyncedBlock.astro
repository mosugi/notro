---
/**
 * Synced block — passes children through as-is.
 */
import { tv } from 'tailwind-variants';

export const syncedBlock = tv({ base: '' });

interface Props { url?: string; class?: string; }
const { url, class: className } = Astro.props;
const hasSource = url != null && url.length > 0;
---

<div class={syncedBlock({ class: className })} data-has-source={hasSource || undefined}>
  <slot />
</div>
