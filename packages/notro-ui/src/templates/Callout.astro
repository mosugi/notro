---
/**
 * Notion callout block.
 * Edit the base classes and color variants to customize callout appearance.
 */
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import { notroColorVariants } from './colors';

export const callout = tv({
  base: 'flex items-start gap-3 my-4 rounded-lg border border-[var(--notro-border)] p-4',
  variants: {
    color: {
      ...notroColorVariants,
      default: 'notro-bg-gray',
    },
  },
  defaultVariants: { color: 'default' },
});

interface Props extends Omit<HTMLAttributes<'div'>, 'color'>, VariantProps<typeof callout> {
  icon?: string;
}

const { icon, color, class: className, ...rest } = Astro.props;
---

<div class={callout({ color, class: className })} {...rest}>
  {icon && <span class="text-xl leading-none shrink-0" aria-hidden="true">{icon}</span>}
  <div class="min-w-0 flex-1 [&>:first-child]:mt-0 [&>:last-child]:mb-0">
    <slot />
  </div>
</div>
