---
/**
 * Notion video embed block.
 */
import { colorToClass } from './colors';

interface Props { src: string; color?: string; class?: string; }
const { src, color, class: className } = Astro.props;
---

<figure class:list={["my-4", colorToClass(color), className]}>
  <video controls src={src} class="w-full"></video>
  {Astro.slots.has('default') && (
    <figcaption class="text-sm text-[var(--notro-text-muted)] mt-1.5">
      <slot />
    </figcaption>
  )}
</figure>
