---
/**
 * Notion image block — renders as <figure> with optional caption.
 */
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

export const imageBlock = tv({ base: 'my-4' });

interface Props extends HTMLAttributes<'figure'> {
  src: string;
  alt?: string;
  caption?: string;
}

const { src, alt, caption, class: className, ...rest } = Astro.props;
---

<figure class={imageBlock({ class: className })} {...rest}>
  <img src={src} alt={alt ?? ''} loading="lazy" decoding="async" class="h-auto max-w-full" />
  {caption && (
    <figcaption class="text-sm text-[var(--notro-text-muted)] mt-1.5 text-center">
      {caption}
    </figcaption>
  )}
</figure>
