---
/**
 * Notion table block.
 * `.notro-table-wrapper` and `.notro-table` selectors are styled in notro-theme.css.
 */
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

export const tableWrapper = tv({
  base: 'notro-table-wrapper my-4 overflow-x-auto',
  variants: { fitPageWidth: { true: 'w-full', false: '' } },
});

export const table = tv({ base: 'notro-table w-full border-collapse text-sm' });

interface Props extends HTMLAttributes<'table'> {
  'fit-page-width'?: string;
  'header-row'?: string;
  'header-column'?: string;
  tableWrapperClass?: string;
}

const {
  'fit-page-width': fitPageWidth = 'false',
  'header-row': headerRow = 'false',
  'header-column': headerColumn = 'false',
  class: className,
  tableWrapperClass,
  ...rest
} = Astro.props;
---

<div class={tableWrapper({ fitPageWidth: fitPageWidth === 'true', class: tableWrapperClass })}>
  <table
    class={table({ class: className })}
    data-header-row={headerRow === 'true' ? '' : undefined}
    data-header-col={headerColumn === 'true' ? '' : undefined}
    {...rest}
  >
    <slot />
  </table>
</div>
