---
/**
 * Notion table block.
 * `.notro-table-wrapper` and `.notro-table` are styled in notro-theme.css.
 */
interface Props {
  'fit-page-width'?: string;
  'header-row'?: string;
  'header-column'?: string;
  class?: string;
  tableWrapperClass?: string;
}

const {
  'fit-page-width': fitPageWidth = 'false',
  'header-row': headerRow = 'false',
  'header-column': headerColumn = 'false',
  class: className,
  tableWrapperClass,
} = Astro.props;
---

<div
  class:list={[
    "notro-table-wrapper my-4 overflow-x-auto",
    fitPageWidth === 'true' && 'w-full',
    tableWrapperClass,
  ]}
>
  <table
    class:list={["notro-table w-full border-collapse text-sm", className]}
    data-header-row={headerRow === 'true' ? '' : undefined}
    data-header-col={headerColumn === 'true' ? '' : undefined}
  >
    <slot />
  </table>
</div>
