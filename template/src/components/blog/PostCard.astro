---
import type { CollectionEntry } from "astro:content";
import { getPlainText, getMultiSelect } from "notro";
import DatabaseCover from "./DatabaseCover.astro";
import config from "../../config";

interface Props {
  data: CollectionEntry<"posts">["data"];
}

const { data } = Astro.props;

const slug = getPlainText(data.properties.Slug) || data.id;
const title = getPlainText(data.properties.Name);
const description = getPlainText(data.properties.Description);
const date = data.properties.Date?.type === "date" ? data.properties.Date.date?.start : undefined;
const tags = getMultiSelect(data.properties.Tags).filter(
  (t) => !config.blog.internalTags.includes(t.name),
);
---

<a
  href={`/blog/${slug}/`}
  class="group block h-full rounded-md border nt-border bg-white overflow-hidden transition-[box-shadow,border-color] no-underline text-inherit hover:nt-border-18 hover:shadow-[rgba(15,15,15,0.06)_0px_2px_8px] dark:bg-slate-800 dark:border-white/8 dark:hover:border-white/15"
>
  <DatabaseCover
    cover={data.cover}
    alt={title}
    class="[&_img]:h-40 [&_img]:w-full [&_img]:object-cover"
  />
  <div class="p-4">
    {date && (
      <time datetime={date} class="block mb-1 text-xs nt-text-45 dark:text-slate-500">
        {date}
      </time>
    )}
    <p class="text-[0.9375rem] font-semibold nt-text line-clamp-2 leading-snug transition-colors group-hover:text-[#2383e2] dark:group-hover:text-blue-400">{title}</p>
    {description && (
      <p class="text-[0.8125rem] nt-text-65 line-clamp-2 leading-relaxed mt-1 dark:text-slate-400">
        {description}
      </p>
    )}
    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1">
        {tags.map((tag) => (
          <span class="text-[0.6875rem] nt-bg-06 nt-text-65 rounded-[3px] px-1.5 py-0.5 dark:bg-white/6 dark:text-slate-400">{tag.name}</span>
        ))}
      </div>
    )}
  </div>
</a>
